<div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>Reference</th>
                <th>Fournisseur</th>
                <th>Date</th>
                <th>Montant</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for order in orders %}
                <tr>
                    <td>
                        <a class="fw-semibold text-decoration-none app-quick-link" href="{{ path('app_supply_order_show', {id: order.id}) }}">{{ order.reference }}</a>
                        <div class="small text-body-secondary">{{ order.status|replace({'_': ' '})|title }}</div>
                    </td>
                    <td>
                        <a class="text-decoration-none app-quick-link fw-semibold" href="{{ path('app_supplier_show', {id: order.supplier.id}) }}">{{ order.supplier.name }}</a>
                    </td>
                    <td>{{ order.orderedAt|date('d/m/Y H:i') }}</td>
                    <td>{{ order.amount|number_format(2, ',', ' ') }} MAD</td>
                    <td class="text-end">
                        <div class="btn-group btn-group-sm">
                            <a href="{{ path('app_supply_order_show', {id: order.id}) }}" class="btn btn-outline-secondary rounded-pill">Voir</a>
                            <a href="{{ path('app_supply_order_edit', {id: order.id}) }}" class="btn btn-outline-primary rounded-pill" data-crud-modal-url="{{ path('app_supply_order_edit', {id: order.id}) }}">Editer</a>
                            <button type="button" class="btn btn-outline-danger rounded-pill" data-crud-delete-url="{{ path('app_supply_order_delete', {id: order.id}) }}" data-crud-refresh-url="{{ path('app_supply_order_list') }}" data-crud-confirm="Supprimer cette commande ?">Supprimer</button>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="5" class="text-center py-4 text-body-secondary">Aucune commande fournisseur disponible.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
