<nav class="navbar navbar-expand-xl sticky-top app-navbar">
    <div class="container-fluid px-3 px-lg-4 px-xxl-5">
        <a class="navbar-brand app-brand d-flex align-items-center gap-3 me-4" href="{{ path('app_home') }}">
            <div class="lh-sm">
                <div class="app-brand-kicker">Relais Medical</div>
                <div class="app-brand-title">Plateforme commerciale</div>
                <div class="app-brand-subtitle">Pilotage, terrain et decisionnel</div>
            </div>
        </a>

        <div class="d-flex align-items-center gap-2 order-xl-3">
            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavigation" aria-controls="mainNavigation" aria-expanded="false" aria-label="Afficher la navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            {% if app.user %}
                <button class="btn app-menu-trigger d-inline-flex align-items-center gap-3 px-3 py-2" type="button" data-bs-toggle="offcanvas" data-bs-target="#userMenuPanel" aria-controls="userMenuPanel">
                    <span class="app-user-avatar d-inline-flex align-items-center justify-content-center">
                        {{ app.user.fullName|split(' ')|map(v => v|first)|join('')|slice(0, 2)|upper }}
                    </span>
                    <span class="text-start lh-sm d-none d-lg-block">
                        <span class="d-block fw-semibold text-dark">{{ app.user.fullName }}</span>
                        <span class="d-block small text-body-secondary">{{ app.user.roleLabels ?: 'Utilisateur' }}</span>
                    </span>
                </button>
            {% endif %}
        </div>

        <div class="collapse navbar-collapse order-xl-2" id="mainNavigation">
            <ul class="navbar-nav mx-auto mb-3 mb-xl-0 app-nav-menu">
                {% if menu_group_visible('pilotage') and (is_granted('ROLE_ADMIN') or is_granted('ROLE_DIRECTION')) %}
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle rounded-4 px-3 py-2 d-flex flex-column align-items-center text-center app-nav-link {{ app.request.attributes.get('_route') in ['app_dashboard'] or app.request.attributes.get('_route') starts with 'app_stats_' or app.request.attributes.get('_route') starts with 'app_market_' or app.request.attributes.get('_route') starts with 'app_objective_' or app.request.attributes.get('_route') starts with 'app_weekly_meeting_' ? 'active' : '' }}" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-bar-chart-line fs-5"></i>
                            <span class="small mt-1">Pilotage</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 rounded-4">
                            {% if menu_visible('pilotage_dashboard') %}<li><a class="dropdown-item" data-turbo="false" href="{{ path('app_dashboard') }}">Dashboard</a></li>{% endif %}
                            {% if menu_visible('pilotage_stats') %}<li><a class="dropdown-item" data-turbo="false" href="{{ path('app_stats_index') }}">Statistiques</a></li>{% endif %}
                            {% if menu_visible('pilotage_market') %}<li><a class="dropdown-item" data-turbo="false" href="{{ path('app_market_index') }}">Marche</a></li>{% endif %}
                            {% if menu_visible('pilotage_objectives') %}<li><a class="dropdown-item" data-turbo="false" href="{{ path('app_objective_index') }}">Objectifs</a></li>{% endif %}
                            {% if menu_visible('pilotage_meetings') %}<li><a class="dropdown-item" data-turbo="false" href="{{ path('app_weekly_meeting_index') }}">Reunions</a></li>{% endif %}
                        </ul>
                    </li>
                {% endif %}

                {% if menu_group_visible('commercial') and (is_granted('ROLE_ADMIN') or is_granted('ROLE_DIRECTION')) %}
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle rounded-4 px-3 py-2 d-flex flex-column align-items-center text-center app-nav-link {{ app.request.attributes.get('_route') starts with 'app_client_' or app.request.attributes.get('_route') starts with 'app_visit_' or app.request.attributes.get('_route') starts with 'app_commercial_' or app.request.attributes.get('_route') starts with 'app_offer_' or app.request.attributes.get('_route') starts with 'app_field_feedback_' or app.request.attributes.get('_route') starts with 'app_customer_satisfaction_' ? 'active' : '' }}" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-people fs-5"></i>
                            <span class="small mt-1">Commercial</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 rounded-4">
                            {% if menu_visible('commercial_clients') %}<li><a class="dropdown-item" data-turbo="false" href="{{ path('app_client_index') }}">Clients</a></li>{% endif %}
                            {% if menu_visible('commercial_client_map') %}<li><a class="dropdown-item" data-turbo="false" href="{{ path('app_client_map') }}">Carte des clients</a></li>{% endif %}
                            {% if menu_visible('commercial_team') %}<li><a class="dropdown-item" data-turbo="false" href="{{ path('app_commercial_index') }}">Commerciaux</a></li>{% endif %}
                            {% if menu_visible('commercial_visits') %}<li><a class="dropdown-item" data-turbo="false" href="{{ path('app_visit_index') }}">Visites</a></li>{% endif %}
                            {% if menu_visible('commercial_offers') %}<li><a class="dropdown-item" data-turbo="false" href="{{ path('app_offer_index') }}">Offres</a></li>{% endif %}
                            {% if menu_visible('commercial_feedback') %}<li><a class="dropdown-item" data-turbo="false" href="{{ path('app_field_feedback_index') }}">Retours terrain</a></li>{% endif %}
                            {% if menu_visible('commercial_satisfaction') %}<li><a class="dropdown-item" data-turbo="false" href="{{ path('app_customer_satisfaction_index') }}">Satisfaction</a></li>{% endif %}
                        </ul>
                    </li>
                {% endif %}

                {% if menu_group_visible('tournees') and (is_granted('ROLE_ADMIN') or is_granted('ROLE_DIRECTION') or is_granted('ROLE_COMMERCIAL')) %}
                    <li class="nav-item">
                        <a class="nav-link rounded-4 px-3 py-2 d-flex flex-column align-items-center text-center app-nav-link {{ app.request.attributes.get('_route') starts with 'app_tour_' ? 'active' : '' }}" href="{{ path('app_tour_index') }}">
                            <i class="bi bi-signpost-split fs-5"></i>
                            <span class="small mt-1">{{ is_granted('ROLE_COMMERCIAL') and not is_granted('ROLE_ADMIN') and not is_granted('ROLE_DIRECTION') ? 'Mes tournees' : 'Tournees' }}</span>
                        </a>
                    </li>
                {% endif %}

                {% if menu_group_visible('rdv') and (is_granted('ROLE_ADMIN') or is_granted('ROLE_DIRECTION') or is_granted('ROLE_COMMERCIAL')) %}
                    <li class="nav-item">
                        <a class="nav-link rounded-4 px-3 py-2 d-flex flex-column align-items-center text-center app-nav-link {{ app.request.attributes.get('_route') starts with 'app_appointment_' ? 'active' : '' }}" href="{{ path('app_appointment_index') }}">
                            <i class="bi bi-calendar-event fs-5"></i>
                            <span class="small mt-1">{{ is_granted('ROLE_COMMERCIAL') and not is_granted('ROLE_ADMIN') and not is_granted('ROLE_DIRECTION') ? 'Mes RDV' : 'RDV' }}</span>
                        </a>
                    </li>
                {% endif %}

                {% if menu_visible('pilotage_objectives') and is_granted('ROLE_COMMERCIAL') and not is_granted('ROLE_ADMIN') and not is_granted('ROLE_DIRECTION') %}
                    <li class="nav-item">
                        <a class="nav-link rounded-4 px-3 py-2 d-flex flex-column align-items-center text-center app-nav-link {{ app.request.attributes.get('_route') starts with 'app_objective_' ? 'active' : '' }}" href="{{ path('app_objective_index') }}">
                            <i class="bi bi-bullseye fs-5"></i>
                            <span class="small mt-1">Objectifs</span>
                        </a>
                    </li>
                {% endif %}

                {% if menu_group_visible('achats') and (is_granted('ROLE_ADMIN') or is_granted('ROLE_ACHAT')) %}
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle rounded-4 px-3 py-2 d-flex flex-column align-items-center text-center app-nav-link {{ app.request.attributes.get('_route') starts with 'app_supplier_' or app.request.attributes.get('_route') starts with 'app_supplier_consultation_' or app.request.attributes.get('_route') starts with 'app_product_' or app.request.attributes.get('_route') starts with 'app_supply_order_' or app.request.attributes.get('_route') starts with 'app_product_launch_project_' ? 'active' : '' }}" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-box-seam fs-5"></i>
                            <span class="small mt-1">Achats</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 rounded-4">
                            {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_DIRECTION') %}
                                {% if menu_visible('achats_suppliers') %}<li><a class="dropdown-item" data-turbo="false" href="{{ path('app_supplier_index') }}">Fournisseurs</a></li>{% endif %}
                                {% if menu_visible('achats_products') %}<li><a class="dropdown-item" data-turbo="false" href="{{ path('app_product_index') }}">Produits</a></li>{% endif %}
                                {% if menu_visible('achats_launches') %}<li><a class="dropdown-item" data-turbo="false" href="{{ path('app_product_launch_project_index') }}">Lancements</a></li>{% endif %}
                            {% endif %}
                            {% if menu_visible('achats_consultations') %}<li><a class="dropdown-item" data-turbo="false" href="{{ path('app_supplier_consultation_index') }}">Consultations</a></li>{% endif %}
                            {% if menu_visible('achats_imports') %}<li><a class="dropdown-item" data-turbo="false" href="{{ path('app_supply_order_index') }}">Imports</a></li>{% endif %}
                        </ul>
                    </li>
                {% endif %}

                {% if menu_group_visible('livraisons') and (is_granted('ROLE_ADMIN') or is_granted('ROLE_LOGISTIQUE')) %}
                    <li class="nav-item">
                        <a class="nav-link rounded-4 px-3 py-2 d-flex flex-column align-items-center text-center app-nav-link {{ app.request.attributes.get('_route') starts with 'app_delivery_' ? 'active' : '' }}" href="{{ path('app_delivery_index') }}">
                            <i class="bi bi-truck-flatbed fs-5"></i>
                            <span class="small mt-1">Livraisons</span>
                        </a>
                    </li>
                {% endif %}

                {% if menu_group_visible('parametrage') and is_granted('ROLE_ADMIN') %}
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle rounded-4 px-3 py-2 d-flex flex-column align-items-center text-center app-nav-link {{ app.request.attributes.get('_route') starts with 'app_settings_' or app.request.attributes.get('_route') starts with 'app_user_' or app.request.attributes.get('_route') starts with 'app_city_' or app.request.attributes.get('_route') starts with 'app_zone_' or app.request.attributes.get('_route') starts with 'app_reference_option_' ? 'active' : '' }}" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-sliders fs-5"></i>
                            <span class="small mt-1">Parametrage</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 rounded-4">
                            {% if menu_visible('parametrage_home') %}<li><a class="dropdown-item" data-turbo="false" href="{{ path('app_settings_index') }}">Vue generale</a></li>{% endif %}
                            {% if menu_visible('parametrage_users') %}<li><a class="dropdown-item" data-turbo="false" href="{{ path('app_user_index') }}">Utilisateurs</a></li>{% endif %}
                            {% if menu_visible('parametrage_cities') %}<li><a class="dropdown-item" data-turbo="false" href="{{ path('app_city_index') }}">Villes</a></li>{% endif %}
                            {% if menu_visible('parametrage_zones') %}<li><a class="dropdown-item" data-turbo="false" href="{{ path('app_zone_index') }}">Zones</a></li>{% endif %}
                            {% if menu_visible('parametrage_choices') %}<li><a class="dropdown-item" data-turbo="false" href="{{ path('app_reference_option_index') }}">Choix</a></li>{% endif %}
                            {% if menu_visible('parametrage_menu') %}<li><a class="dropdown-item" data-turbo="false" href="{{ path('app_settings_menu') }}">Gestion du menu</a></li>{% endif %}
                        </ul>
                    </li>
                {% endif %}
            </ul>
        </div>
    </div>
</nav>

{% if app.user %}
    <div class="offcanvas offcanvas-end" tabindex="-1" id="userMenuPanel" aria-labelledby="userMenuPanelLabel">
        <div class="offcanvas-header px-4 pt-4 pb-3 border-bottom">
            <div>
                <div class="app-section-kicker text-secondary mb-1">Espace utilisateur</div>
                <h2 class="h4 mb-0" id="userMenuPanelLabel">Mon compte</h2>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Fermer"></button>
        </div>
        <div class="offcanvas-body p-4 d-flex flex-column gap-4">
            <div class="app-user-summary rounded-5 p-4">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="app-user-avatar d-inline-flex align-items-center justify-content-center">
                        {{ app.user.fullName|split(' ')|map(v => v|first)|join('')|slice(0, 2)|upper }}
                    </div>
                    <div class="min-w-0">
                        <div class="fw-bold text-dark">{{ app.user.fullName }}</div>
                        <div class="small text-body-secondary text-break">{{ app.user.userIdentifier }}</div>
                    </div>
                </div>
                <div class="small text-body-secondary">Role</div>
                <div class="fw-semibold">{{ app.user.roleLabels ?: 'Utilisateur' }}</div>
            </div>

            <div class="d-grid gap-3">
                <a href="{{ path('app_home') }}" class="app-user-panel-link">
                    <span class="app-user-panel-icon"><i class="bi bi-house-door"></i></span>
                    <span>
                        <span class="d-block fw-semibold">Accueil</span>
                        <span class="small text-body-secondary">Retour au point d'entree de l'application</span>
                    </span>
                </a>
            </div>

            <div class="mt-auto">
                <a href="{{ path('app_logout') }}" class="btn btn-danger w-100 py-3">
                    <i class="bi bi-box-arrow-right me-2"></i>
                </a>
            </div>
        </div>
    </div>
{% endif %}
