<div class="table-responsive">
    <table class="table align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>Categorie</th>
                <th>Libelle</th>
                <th>Valeur</th>
                <th>Ordre</th>
                <th>Etat</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for option in options %}
                <tr>
                    <td><span class="badge rounded-pill text-bg-light">{{ option.category|replace({'_': ' '})|title }}</span></td>
                    <td class="fw-semibold">{{ option.label }}</td>
                    <td><code>{{ option.value }}</code></td>
                    <td>{{ option.sortOrder }}</td>
                    <td><span class="badge rounded-pill {{ option.isActive ? 'text-bg-success' : 'text-bg-secondary' }}">{{ option.isActive ? 'Active' : 'Inactive' }}</span></td>
                    <td class="text-end">
                        <div class="d-inline-flex gap-2">
                            <a href="{{ path('app_reference_option_show', {id: option.id}) }}" class="btn btn-outline-secondary rounded-pill">Voir</a>
                            <a href="{{ path('app_reference_option_edit', {id: option.id}) }}" class="btn btn-outline-primary rounded-pill" data-crud-modal-url="{{ path('app_reference_option_edit', {id: option.id}) }}">Editer</a>
                            <button type="button" class="btn btn-outline-danger rounded-pill" data-crud-delete-url="{{ path('app_reference_option_delete', {id: option.id}) }}" data-crud-refresh-url="{{ path('app_reference_option_list') }}" data-crud-confirm="Supprimer {{ option.label }} ?">Supprimer</button>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="text-center py-4 text-body-secondary">Aucun choix disponible.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
