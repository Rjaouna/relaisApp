<div class="modal-header">
    <h5 class="modal-title">Preparer des visites</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
</div>
<form
    method="post"
    action="{{ path('app_visit_new') }}"
    data-crud-ajax-form
    data-crud-refresh-url="{{ path('app_visit_list') }}"
    data-visit-batch-form
>
    <div class="modal-body">
        <div class="d-flex flex-column gap-3">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <div class="text-body-secondary small text-uppercase mb-2">Preparation admin</div>
                    <h2 class="h5 mb-1">Choisir les clients sans visite ouverte</h2>
                    <p class="text-body-secondary mb-0">L administrateur prepare juste les visites. Le commercial completera ensuite le suivi terrain.</p>
                </div>
                <button
                    type="button"
                    class="btn btn-outline-primary rounded-pill"
                    data-bs-toggle="collapse"
                    data-bs-target="#visit-batch-client-list"
                    aria-expanded="true"
                    aria-controls="visit-batch-client-list"
                >
                    <i class="bi bi-people me-2"></i>Afficher les clients disponibles
                </button>
            </div>

            {% if selectionError %}
                <div class="alert alert-danger rounded-4 mb-0">{{ selectionError }}</div>
            {% endif %}

            <div class="card border-0 bg-body-tertiary rounded-4">
                <div class="card-body p-3 d-flex flex-column flex-lg-row gap-2 justify-content-between align-items-lg-center">
                    <div class="small text-body-secondary">
                        <span class="fw-semibold" data-visit-batch-selected-count>0</span> client(s) selectionne(s)
                    </div>
                    <div class="d-flex gap-2 flex-wrap">
                        <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill" data-visit-batch-select-all>Tout selectionner</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill" data-visit-batch-deselect-all>Tout deselectionner</button>
                    </div>
                </div>
            </div>

            <div id="visit-batch-client-list" class="collapse show">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden" data-list-search-scope>
                    {% include '_partials/_listing_search.html.twig' with {
                        placeholder: 'Rechercher un client disponible...',
                        target: '[data-visit-batch-row]'
                    } %}
                    <div class="table-responsive" style="max-height: 24rem;">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th style="width: 3rem;"></th>
                                    <th>Client</th>
                                    <th>Ville</th>
                                    <th>Zone</th>
                                    <th>Statut</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for client in availableClients %}
                                    <tr data-visit-batch-row>
                                        <td>
                                            <input class="form-check-input" type="checkbox" name="client_ids[]" value="{{ client.id }}" data-visit-batch-checkbox>
                                        </td>
                                        <td>
                                            <div class="fw-semibold">{{ client.name }}</div>
                                            <div class="small text-body-secondary">{{ client.type|title }}</div>
                                        </td>
                                        <td>{{ client.city ?: 'Non definie' }}</td>
                                        <td>{{ client.zone ? client.zone.name : 'Sans zone' }}</td>
                                        <td>
                                            <span class="badge rounded-pill
                                                {% if client.status == 'actif' %}text-bg-success
                                                {% elseif client.status == 'en_cours' %}text-bg-info
                                                {% elseif client.status == 'refuse' %}text-bg-danger
                                                {% else %}text-bg-warning{% endif %}">
                                                {{ client.status|replace({'_': ' '})|title }}
                                            </span>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="5" class="text-center py-4 text-body-secondary">
                                            Tous les clients ont deja une visite ouverte ou en attente.
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-plus-circle me-2"></i>Ajouter a la liste
        </button>
    </div>
</form>
