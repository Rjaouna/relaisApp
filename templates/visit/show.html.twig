{% extends 'base.html.twig' %}

{% block title %}Detail visite{% endblock %}

{% block body %}
    {% set isPastVisit = visit.scheduledAt < date() %}
    {% set isOverduePlannedVisit = isPastVisit and visit.status == 'prevue' %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <div class="text-body-secondary small text-uppercase mb-2">Fiche visite</div>
            <h1 class="h2 mb-1">{{ visit.client.name }}</h1>
            <p class="text-body-secondary mb-0">{{ visit.client.city }}</p>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('app_visit_index') }}" class="btn btn-outline-secondary rounded-pill px-4"><i class="bi bi-arrow-left me-2"></i>Retour</a>
            <a href="{{ path('app_visit_edit', {id: visit.id}) }}" class="btn btn-primary rounded-pill px-4" data-crud-modal-url="{{ path('app_visit_edit', {id: visit.id}) }}">Modifier</a>
        </div>
    </div>

    {% if isOverduePlannedVisit %}
        <div class="alert alert-danger border-0 rounded-4 shadow-sm mb-4">
            Cette visite est passee mais reste au statut <strong>prevue</strong>. Elle demande une action rapide.
        </div>
    {% elseif isPastVisit %}
        <div class="alert alert-secondary border-0 rounded-4 shadow-sm mb-4">
            Cette visite est deja passee.
        </div>
    {% endif %}

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-5">
                <div class="card-body p-4">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Date</dt>
                        <dd class="col-sm-8">
                            {{ visit.scheduledAt|date('d/m/Y H:i') }}
                            {% if isOverduePlannedVisit %}
                                <span class="badge rounded-pill text-bg-danger ms-2">En retard</span>
                            {% elseif isPastVisit %}
                                <span class="badge rounded-pill text-bg-secondary ms-2">Passee</span>
                            {% endif %}
                        </dd>
                        <dt class="col-sm-4">Creation</dt>
                        <dd class="col-sm-8">{{ visit.createdAt|date('d/m/Y H:i') }}</dd>
                        <dt class="col-sm-4">Type</dt>
                        <dd class="col-sm-8">{{ visit.type|title }}</dd>
                        <dt class="col-sm-4">Priorite</dt>
                        <dd class="col-sm-8">{{ visit.priority|title }}</dd>
                        <dt class="col-sm-4">Statut</dt>
                        <dd class="col-sm-8">{{ visit.status|replace({'_': ' '})|title }}</dd>
                        <dt class="col-sm-4">Resultat</dt>
                        <dd class="col-sm-8">{{ visit.result ? visit.result|replace({'_': ' '})|title : 'Non renseigne' }}</dd>
                        <dt class="col-sm-4">RDV programme</dt>
                        <dd class="col-sm-8">
                            {% if visit.appointmentScheduledAt %}
                                {{ visit.appointmentScheduledAt|date('d/m/Y H:i') }}
                                <a href="{{ path('app_appointment_index') }}" class="btn btn-sm btn-outline-primary rounded-pill ms-2">Voir les RDV</a>
                            {% else %}
                                Aucun rendez-vous defini
                            {% endif %}
                        </dd>
                        <dt class="col-sm-4">Interet</dt>
                        <dd class="col-sm-8">{{ visit.interestLevel ?: 'Non renseigne' }}</dd>
                        <dt class="col-sm-4">Controle admin</dt>
                        <dd class="col-sm-8">
                            {% if visit.adminReviewStatus == 'validee' %}
                                <span class="badge rounded-pill text-bg-success">Validee</span>
                            {% elseif visit.adminReviewStatus == 'rejetee' %}
                                <span class="badge rounded-pill text-bg-danger">Rejetee</span>
                            {% elseif visit.adminReviewStatus == 'en_attente' %}
                                <span class="badge rounded-pill text-bg-warning">En attente</span>
                            {% else %}
                                <span class="badge rounded-pill text-bg-secondary">Non controlee</span>
                            {% endif %}
                        </dd>
                        <dt class="col-sm-4">Archivage</dt>
                        <dd class="col-sm-8">
                            {% if visit.archivedAt %}
                                <span class="badge rounded-pill text-bg-secondary">Archivee</span>
                                <span class="small text-body-secondary ms-2">{{ visit.archivedAt|date('d/m/Y H:i') }}</span>
                            {% else %}
                                <span class="badge rounded-pill text-bg-light">Active</span>
                            {% endif %}
                        </dd>
                        {% if visit.adminReviewComment %}
                            <dt class="col-sm-4">Commentaire admin</dt>
                            <dd class="col-sm-8">{{ visit.adminReviewComment }}</dd>
                        {% endif %}
                    </dl>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-5">
                <div class="card-body p-4">
                    <h2 class="h5">Objectif</h2>
                    <p>{{ visit.objective ?: 'Aucun objectif defini.' }}</p>
                    <h2 class="h5">Compte rendu</h2>
                    <p>{{ visit.report ?: 'Aucun compte rendu disponible.' }}</p>
                    <h2 class="h5">Prochaine action</h2>
                    <p class="mb-0">{{ visit.nextAction ?: 'Aucune action definie.' }}</p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
