{% extends 'base.html.twig' %}

{% block title %}Resultat de visite{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-5 overflow-hidden mb-4">
                <div class="card-body bg-dark text-white p-4">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="text-white-50 small text-uppercase mb-2">Compte rendu terrain</div>
                            <h1 class="h3 mb-1">{{ visit.client.name }}</h1>
                            <p class="text-white-50 mb-0">
                                {{ visit.scheduledAt|date('d/m/Y H:i') }} - {{ visit.type|replace({'_': ' '})|title }}
                            </p>
                        </div>
                        <a href="{{ tourId ? path('app_tour_show', {id: tourId}) : path('app_home') }}" class="btn btn-outline-light rounded-pill">Retour</a>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-5">
                <div class="card-body p-4 p-lg-5">
                    {{ form_start(form, { attr: { 'data-appointment-modal-form': true } }) }}
                        <div class="row g-3">
                            <div class="col-md-6">{% include '_partials/_reference_option_field.html.twig' with { field: form.result, category: 'visit_result' } %}</div>
                            <div class="col-md-6 d-none">
                                {{ form_row(form.appointmentScheduledAt, { attr: form.appointmentScheduledAt.vars.attr|merge({ 'data-appointment-modal-source': true }) }) }}
                            </div>
                            <div class="col-12 d-none" data-appointment-summary>
                                <div class="alert alert-info border-0 rounded-4 mb-0">
                                    <div class="fw-semibold mb-1">Rendez-vous programme</div>
                                    <div class="small text-body-secondary" data-appointment-summary-text>Aucune date definie.</div>
                                    <button type="button" class="btn btn-sm btn-outline-primary rounded-pill mt-3" data-appointment-open-modal>
                                        <i class="bi bi-calendar-event me-2"></i>Modifier la date du rendez-vous
                                    </button>
                                </div>
                            </div>
                            <div class="col-12">{% include '_partials/_interest_level_field.html.twig' with { field: form.interestLevel } %}</div>
                            <div class="col-12">{{ form_row(form.report) }}</div>
                            <div class="col-12">{{ form_row(form.nextAction) }}</div>
                        </div>
                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a href="{{ tourId ? path('app_tour_show', {id: tourId}) : path('app_home') }}" class="btn btn-outline-secondary rounded-pill px-4">Annuler</a>
                            <button type="submit" class="btn btn-primary rounded-pill px-4">Enregistrer le resultat</button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="appointmentSchedulingModal" tabindex="-1" aria-labelledby="appointmentSchedulingModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-5">
                <div class="modal-header border-0 pb-0">
                    <div>
                        <div class="text-body-secondary small text-uppercase mb-1">Rendez-vous a programmer</div>
                        <h2 class="h5 mb-0" id="appointmentSchedulingModalLabel">Choisir la date du RDV</h2>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>
                <div class="modal-body pt-3">
                    <p class="text-body-secondary mb-3">Le rendez-vous sera automatiquement ajoute dans la rubrique <strong>RDV</strong> avec le client, le commercial et la visite source.</p>
                    <label class="form-label" for="appointmentSchedulingModalInput">Date et heure du rendez-vous</label>
                    <input type="datetime-local" class="form-control" id="appointmentSchedulingModalInput" data-appointment-modal-input>
                    <div class="form-text">Choisis directement le prochain point de contact avec ce client.</div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Annuler</button>
                    <button type="button" class="btn btn-primary rounded-pill px-4" data-appointment-modal-confirm>Valider le rendez-vous</button>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
