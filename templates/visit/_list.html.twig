{% set history_mode = history_mode|default(false) %}
<div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>Client</th>
                <th>Date</th>
                <th>Type</th>
                <th>Statut</th>
                <th>Resultat</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for visit in visits %}
                {% set isPastVisit = visit.scheduledAt < date() %}
                {% set isOverduePlannedVisit = isPastVisit and visit.status == 'prevue' %}
                {% set isNewVisit = visit.status == 'prevue' and not visit.result %}
                <tr class="{{ isOverduePlannedVisit ? 'app-visit-row-overdue' : (isPastVisit ? 'app-visit-row-past' : '') }}">
                    <td>
                        <div class="d-flex flex-wrap align-items-center gap-2">
                            <a class="fw-semibold text-decoration-none app-quick-link" href="{{ path('app_client_show', {id: visit.client.id}) }}">{{ visit.client.name }}</a>
                            {% if isNewVisit %}
                                <span class="badge rounded-pill text-bg-primary">New</span>
                            {% endif %}
                        </div>
                        <div class="small text-body-secondary">{{ visit.client.city }}</div>
                    </td>
                    <td>
                        <div>{{ visit.scheduledAt|date('d/m/Y H:i') }}</div>
                        {% if history_mode %}
                            <div class="small text-body-secondary mt-1">Creee le {{ visit.createdAt|date('d/m/Y H:i') }}</div>
                        {% endif %}
                        {% if isOverduePlannedVisit %}
                            <span class="badge rounded-pill text-bg-danger mt-2">En retard</span>
                        {% elseif isPastVisit %}
                            <span class="badge rounded-pill text-bg-secondary mt-2">Passee</span>
                        {% endif %}
                    </td>
                    <td><span class="badge rounded-pill text-bg-light">{{ visit.type|title }}</span></td>
                    <td>
                        <span class="badge rounded-pill {{ isOverduePlannedVisit ? 'text-bg-danger' : 'text-bg-light' }}">
                            {{ visit.status|replace({'_': ' '})|title }}
                        </span>
                    </td>
                    <td>{{ visit.result ? visit.result|replace({'_': ' '})|title : 'Non renseigne' }}</td>
                    <td class="text-end">
                        <div class="btn-group btn-group-sm">
                            <a href="{{ path('app_visit_show', {id: visit.id}) }}" class="btn btn-outline-secondary rounded-pill">Voir</a>
                            {% if not history_mode %}
                                <a href="{{ path('app_visit_edit', {id: visit.id}) }}" class="btn btn-outline-primary rounded-pill" data-crud-modal-url="{{ path('app_visit_edit', {id: visit.id}) }}">Editer</a>
                                <button type="button" class="btn btn-outline-danger rounded-pill" data-crud-delete-url="{{ path('app_visit_delete', {id: visit.id}) }}" data-crud-refresh-url="{{ path('app_visit_list') }}" data-crud-confirm="Supprimer cette visite ?">Supprimer</button>
                            {% endif %}
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="6" class="text-center py-4 text-body-secondary">Aucune visite disponible.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
