{% extends 'base.html.twig' %}

{% block title %}Historique des visites{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <div class="text-body-secondary small text-uppercase mb-2">Historique terrain</div>
            <h1 class="h3 mb-1">Visites archivees</h1>
            <p class="text-body-secondary mb-0">Retrouve toutes les visites deja lancees et archivees avec leur date, leur resultat et leur contexte.</p>
        </div>
        <a href="{{ path('app_visit_index') }}" class="btn btn-outline-secondary rounded-pill px-4"><i class="bi bi-arrow-left me-2"></i>Retour aux visites actives</a>
    </div>

    <div class="card border-0 shadow-sm rounded-5 overflow-hidden" data-list-search-scope>
        {% include '_partials/_listing_search.html.twig' with { placeholder: 'Rechercher une visite archivee...' } %}
        <div class="card-body p-0">
            {% include 'visit/_list.html.twig' with { visits: visits, history_mode: true } %}
        </div>
    </div>
{% endblock %}
