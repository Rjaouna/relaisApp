{% extends 'base.html.twig' %}

{% block title %}Detail projet de lancement{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <div class="text-body-secondary small text-uppercase mb-2">Projet de lancement</div>
            <h1 class="h2 mb-0">{{ project.name }}</h1>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('app_product_launch_project_index') }}" class="btn btn-outline-secondary rounded-pill px-4"><i class="bi bi-arrow-left me-2"></i>Retour</a>
            <a href="{{ path('app_product_launch_project_edit', {id: project.id}) }}" class="btn btn-primary rounded-pill px-4" data-crud-modal-url="{{ path('app_product_launch_project_edit', {id: project.id}) }}">Modifier</a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-5 h-100">
                <div class="card-body p-4">
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <span class="badge rounded-pill text-bg-light">{{ project.status|title }}</span>
                        {% if project.registrationRequired %}
                            <span class="badge rounded-pill text-bg-warning">Enregistrement requis</span>
                        {% endif %}
                    </div>
                    <dl class="row mb-0">
                        <dt class="col-sm-5">Produit</dt>
                        <dd class="col-sm-7">
                            {% if project.product %}
                                <a class="text-decoration-none" href="{{ path('app_product_show', {id: project.product.id}) }}">{{ project.product.name }}</a>
                            {% else %}
                                Non rattache
                            {% endif %}
                        </dd>
                        <dt class="col-sm-5">Ville cible</dt>
                        <dd class="col-sm-7">{{ project.targetCity ?: 'Non definie' }}</dd>
                        <dt class="col-sm-5">Cible</dt>
                        <dd class="col-sm-7">{{ project.targetEntities ?: 'A preciser' }}</dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-5">
                <div class="card-body p-4">
                    <div class="small text-uppercase text-body-secondary mb-2">Etude de marche</div>
                    <p class="mb-4">{{ project.marketStudy ?: 'Aucune etude de marche renseignee.' }}</p>
                    <div class="small text-uppercase text-body-secondary mb-2">Faisabilite</div>
                    <p class="mb-4">{{ project.feasibilityNotes ?: 'Aucune note de faisabilite.' }}</p>
                    <div class="small text-uppercase text-body-secondary mb-2">Conditions d import</div>
                    <p class="mb-4">{{ project.importConditions ?: 'Aucune condition d import renseignee.' }}</p>
                    <div class="small text-uppercase text-body-secondary mb-2">Suivi / recadrage</div>
                    <p class="mb-0">{{ project.followUpNotes ?: 'Aucun suivi formalise.' }}</p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
