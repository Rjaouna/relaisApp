<div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>Projet</th>
                <th>Produit</th>
                <th>Cible</th>
                <th>Phase</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for project in projects %}
                <tr>
                    <td>
                        <a class="fw-semibold text-decoration-none" href="{{ path('app_product_launch_project_show', {id: project.id}) }}">{{ project.name }}</a>
                        <div class="small text-body-secondary">{{ project.feasibilityNotes ? (project.feasibilityNotes|length > 90 ? project.feasibilityNotes|slice(0, 90) ~ '...' : project.feasibilityNotes) : 'Projet sans note de faisabilite' }}</div>
                    </td>
                    <td>
                        {% if project.product %}
                            <a class="text-decoration-none" href="{{ path('app_product_show', {id: project.product.id}) }}">{{ project.product.name }}</a>
                        {% else %}
                            <span class="text-body-secondary">Hors catalogue</span>
                        {% endif %}
                    </td>
                    <td>
                        <div>{{ project.targetCity ?: 'Ville a definir' }}</div>
                        <div class="small text-body-secondary">{{ project.targetEntities ? (project.targetEntities|length > 50 ? project.targetEntities|slice(0, 50) ~ '...' : project.targetEntities) : 'Cible a preciser' }}</div>
                    </td>
                    <td>
                        <span class="badge rounded-pill text-bg-light">{{ project.status|title }}</span>
                        {% if project.registrationRequired %}
                            <div class="small text-body-secondary mt-2">Enregistrement requis</div>
                        {% endif %}
                    </td>
                    <td class="text-end">
                        <div class="btn-group btn-group-sm">
                            <a href="{{ path('app_product_launch_project_show', {id: project.id}) }}" class="btn btn-outline-secondary rounded-pill">Voir</a>
                            <a href="{{ path('app_product_launch_project_edit', {id: project.id}) }}" class="btn btn-outline-primary rounded-pill" data-crud-modal-url="{{ path('app_product_launch_project_edit', {id: project.id}) }}">Editer</a>
                            <button type="button" class="btn btn-outline-danger rounded-pill" data-crud-delete-url="{{ path('app_product_launch_project_delete', {id: project.id}) }}" data-crud-refresh-url="{{ path('app_product_launch_project_list') }}" data-crud-confirm="Supprimer ce projet de lancement ?">Supprimer</button>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="5" class="text-center py-4 text-body-secondary">Aucun projet de lancement disponible.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
