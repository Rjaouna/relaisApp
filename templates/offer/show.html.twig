{% extends 'base.html.twig' %}

{% block title %}Detail offre{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <div class="text-body-secondary small text-uppercase mb-2">Fiche offre</div>
            <h1 class="h2 mb-1">{{ offer.reference }}</h1>
            <p class="text-body-secondary mb-0">{{ offer.client.name }}</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a href="{{ path('app_offer_edit', {id: offer.id}) }}" class="btn btn-outline-primary px-4" data-crud-modal-url="{{ path('app_offer_edit', {id: offer.id}) }}"><i class="bi bi-pencil-square me-2"></i>Editer</a>
            <a href="{{ path('app_offer_index') }}" class="btn btn-outline-secondary px-4"><i class="bi bi-arrow-left me-2"></i>Retour</a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-5">
                <div class="card-body p-4">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Date</dt>
                        <dd class="col-sm-8">{{ offer.issuedAt|date('d/m/Y') }}</dd>
                        <dt class="col-sm-4">Montant</dt>
                        <dd class="col-sm-8">{{ offer.amount|number_format(2, ',', ' ') }} MAD</dd>
                        <dt class="col-sm-4">Statut</dt>
                        <dd class="col-sm-8">{{ offer.status|replace({'_': ' '})|title }}</dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-5">
                <div class="card-body p-4">
                    <h2 class="h5">Conditions</h2>
                    <p>{{ offer.conditionsSummary ?: 'Aucune condition definie.' }}</p>
                    <h2 class="h5">Historique</h2>
                    <p class="mb-0">{{ offer.historyNotes ?: 'Aucun historique disponible.' }}</p>
                </div>
            </div>
        </div>
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-5 overflow-hidden">
                <div class="card-body p-4 border-bottom">
                    <h2 class="h5 mb-1">Articles proposes</h2>
                    <p class="text-body-secondary mb-0">Liste detaillee des produits inclus dans cette offre.</p>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Article</th>
                                <th>Quantite</th>
                                <th>Prix unitaire</th>
                                <th>Total ligne</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for item in offer.items %}
                                <tr>
                                    <td>
                                        <div class="fw-semibold">{{ item.product.name }}</div>
                                        <div class="small text-body-secondary">{{ item.product.category }}</div>
                                    </td>
                                    <td>{{ item.quantity }}</td>
                                    <td>{{ item.unitPrice|number_format(2, ',', ' ') }} MAD</td>
                                    <td class="fw-semibold">{{ item.lineTotal|number_format(2, ',', ' ') }} MAD</td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="4" class="text-center py-4 text-body-secondary">Aucun article rattache a cette offre.</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
