<div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>Reference</th>
                <th>Client</th>
                <th>Date</th>
                <th>Montant</th>
                <th>Statut</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for offer in offers %}
                <tr>
                    <td>
                        <a class="fw-semibold text-decoration-none app-quick-link" href="{{ path('app_offer_show', {id: offer.id}) }}">{{ offer.reference }}</a>
                        <div class="small text-body-secondary">{{ offer.client.city }}</div>
                    </td>
                    <td>
                        <a class="text-decoration-none app-quick-link fw-semibold" href="{{ path('app_client_show', {id: offer.client.id}) }}">{{ offer.client.name }}</a>
                    </td>
                    <td>{{ offer.issuedAt|date('d/m/Y') }}</td>
                    <td><span class="fw-semibold">{{ offer.amount|number_format(2, ',', ' ') }}</span> MAD</td>
                    <td><span class="badge rounded-pill text-bg-light">{{ offer.status|replace({'_': ' '})|title }}</span></td>
                    <td class="text-end">
                        <div class="btn-group btn-group-sm app-action-group">
                            <a href="{{ path('app_offer_show', {id: offer.id}) }}" class="btn btn-outline-secondary rounded-pill">Voir</a>
                            <a href="{{ path('app_offer_edit', {id: offer.id}) }}" class="btn btn-outline-primary rounded-pill" data-crud-modal-url="{{ path('app_offer_edit', {id: offer.id}) }}">Editer</a>
                            <button type="button" class="btn btn-outline-danger rounded-pill" data-crud-delete-url="{{ path('app_offer_delete', {id: offer.id}) }}" data-crud-refresh-url="{{ path('app_offer_list') }}" data-crud-confirm="Supprimer {{ offer.reference }} ?">Supprimer</button>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="6" class="text-center py-4 text-body-secondary">Aucune offre disponible.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
