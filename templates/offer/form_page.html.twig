{% extends 'base.html.twig' %}

{% block title %}{{ offer.id ? 'Modifier l offre' : 'Ajouter une offre' }}{% endblock %}

{% block body %}
    <div class="card border-0 rounded-5">
        <div class="card-body p-4 p-lg-5">
            <h1 class="h3 mb-4">{{ offer.id ? 'Modifier l offre' : 'Ajouter une offre' }}</h1>
            {{ form_start(form) }}
                <div class="row g-3">
                    <div class="col-md-6">{{ form_row(form.reference) }}</div>
                    <div class="col-md-6">{{ form_row(form.client) }}</div>
                    <div class="col-md-6">{{ form_row(form.issuedAt) }}</div>
                    <div class="col-md-6">{{ form_row(form.amount) }}</div>
                    <div class="col-md-6">{% include '_partials/_reference_option_field.html.twig' with { field: form.status, category: 'offer_status' } %}</div>
                    <div class="col-12">{{ form_row(form.conditionsSummary) }}</div>
                    <div class="col-12">{{ form_row(form.historyNotes) }}</div>
                    <div class="col-12">
                        <div class="card border-0 bg-body-tertiary rounded-5">
                            <div class="card-body p-3 p-lg-4">
                                <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-3">
                                    <div>
                                        <h6 class="mb-1">Articles de l'offre</h6>
                                        <p class="text-body-secondary small mb-0">Ajoute les produits proposes et laisse le total se calculer automatiquement.</p>
                                    </div>
                                    <button type="button" class="btn btn-outline-primary" data-offer-item-add>
                                        <i class="bi bi-plus-lg me-2"></i>Ajouter un article
                                    </button>
                                </div>
                                <div
                                    data-offer-items
                                    data-offer-items-index="{{ form.items|length }}"
                                    data-offer-items-prototype="{{ include('offer/_item_form.html.twig', { itemForm: form.items.vars.prototype })|e('html_attr') }}"
                                >
                                    {% for itemForm in form.items %}
                                        {% include 'offer/_item_form.html.twig' with { itemForm: itemForm } %}
                                    {% else %}
                                        <div class="rounded-4 border border-dashed p-4 text-center text-body-secondary bg-white" data-offer-items-empty>
                                            Aucun article ajoute pour le moment.
                                        </div>
                                    {% endfor %}
                                </div>
                                <div class="rounded-4 bg-white border p-3 mt-3 d-flex align-items-center justify-content-between">
                                    <div class="small text-body-secondary">Montant estime de l'offre</div>
                                    <div class="h5 fw-bold mb-0" data-offer-total-display>{{ offer.amount|number_format(2, ',', ' ') }} MAD</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="d-flex gap-2 mt-4">
                    <a href="{{ path('app_offer_index') }}" class="btn btn-outline-secondary">Annuler</a>
                    <button type="submit" class="btn btn-primary">Enregistrer</button>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
