<div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>Nom</th>
                <th>Ville</th>
                <th>Type</th>
                <th>Statut</th>
                <th>Commercial</th>
                <th>CA annuel</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for client in clients %}
                <tr>
                    <td>
                        {% set show_route = (read_only|default(false)) and client.status == constant('App\\Entity\\Client::STATUS_REFUSED') ? 'app_client_refused_show' : 'app_client_show' %}
                        <a class="fw-semibold text-decoration-none app-quick-link" href="{{ path(show_route, {id: client.id}) }}">{{ client.name }}</a>
                        <div class="small text-body-secondary">{{ client.email ?: 'Aucun email' }}</div>
                    </td>
                    <td>
                        <div>{{ client.city }}</div>
                        <div class="small text-body-secondary">{{ client.zone ? client.zone.name : 'Zone non definie' }}</div>
                    </td>
                    <td><span class="badge rounded-pill text-bg-light">{{ client.type|replace({'_': ' '})|title }}</span></td>
                    <td><span class="badge rounded-pill text-bg-light">{{ client.status|replace({'_': ' '})|title }}</span></td>
                    <td>
                        {% if client.assignedCommercial %}
                            <a class="text-decoration-none app-quick-link fw-semibold" href="{{ path('app_commercial_show', {id: client.assignedCommercial.id}) }}">{{ client.assignedCommercial.fullName }}</a>
                        {% else %}
                            Non affecte
                        {% endif %}
                    </td>
                    <td><span class="fw-semibold">{{ client.annualRevenue|number_format(2, ',', ' ') }}</span> MAD</td>
                    <td class="text-end">
                        {% if read_only|default(false) %}
                            <a href="{{ path(show_route, {id: client.id}) }}" class="btn btn-outline-secondary rounded-pill">Voir</a>
                        {% else %}
                            <div class="btn-group btn-group-sm">
                                <a href="{{ path('app_client_show', {id: client.id}) }}" class="btn btn-outline-secondary rounded-pill">Voir</a>
                                <a href="{{ path('app_client_edit', {id: client.id}) }}" class="btn btn-outline-primary rounded-pill" data-crud-modal-url="{{ path('app_client_edit', {id: client.id}) }}">Editer</a>
                                <button type="button"
                                        class="btn btn-outline-danger rounded-pill"
                                        data-crud-delete-url="{{ path('app_client_delete', {id: client.id}) }}"
                                        data-crud-refresh-url="{{ path('app_client_list') }}"
                                        data-crud-confirm="Supprimer {{ client.name }} ?">
                                    Supprimer
                                </button>
                            </div>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7" class="text-center py-4 text-body-secondary">{{ empty_message|default('Aucun client enregistre pour le moment.') }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
