{% extends 'base.html.twig' %}

{% block title %}Clients refuses{% endblock %}

{% block body %}
    <section class="app-page-hero rounded-5 p-4 p-lg-5 mb-4">
        <div class="d-flex flex-column flex-xl-row justify-content-between gap-4 align-items-xl-center">
            <div class="pe-xl-4">
                <span class="badge rounded-pill text-bg-danger mb-3">Lecture seule</span>
                <h1 class="h2 mb-2">Clients refuses</h1>
                <p class="text-body-secondary mb-0">Cette rubrique permet de consulter uniquement les clients refuses. Aucune modification n est autorisee depuis cet ecran.</p>
            </div>
            <div class="d-flex flex-wrap gap-2 justify-content-xl-end">
                <a href="{{ path('app_client_index') }}" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-2"></i>Retour aux clients
                </a>
            </div>
        </div>
    </section>

    <div class="card border-0 shadow-sm rounded-5 overflow-hidden" data-list-search-scope>
        {% include '_partials/_listing_search.html.twig' with { placeholder: 'Rechercher un client refuse, une ville ou une zone...', target: 'tbody tr' } %}
        <div class="card-body p-0">
            {% include 'client/_list.html.twig' with {
                clients: clients,
                empty_message: 'Aucun client refuse pour le moment.',
                read_only: true
            } %}
        </div>
    </div>
{% endblock %}
