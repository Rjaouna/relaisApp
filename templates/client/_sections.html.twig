<div class="row g-4">
    <div class="col-12 col-xxl-6">
        <section class="card border-0 shadow-sm rounded-5 overflow-hidden h-100" data-list-search-scope>
            <div class="card-body p-4 p-lg-4 border-bottom">
                <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
                    <div>
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="badge rounded-pill text-bg-warning-subtle text-warning-emphasis px-3">Prospection</span>
                            <span class="badge rounded-pill text-bg-light px-3">{{ counters.prospection }}</span>
                        </div>
                        <h2 class="h4 mb-1">Prospects a suivre</h2>
                        <p class="text-body-secondary mb-0">Regroupe les clients `potentiel` et `en cours` pour les actions commerciales du moment.</p>
                    </div>
                    <a href="{{ path('app_client_new') }}" class="btn btn-primary" data-crud-modal-url="{{ path('app_client_new') }}">
                        <i class="bi bi-plus-lg me-2"></i>Nouveau prospect
                    </a>
                </div>
            </div>
            {% include '_partials/_listing_search.html.twig' with { placeholder: 'Rechercher dans la prospection...', target: 'tbody tr' } %}
            <div class="card-body p-0">
                {% include 'client/_list.html.twig' with {
                    clients: groupedClients.prospection,
                    empty_message: 'Aucun prospect a suivre pour le moment.'
                } %}
            </div>
        </section>
    </div>

    <div class="col-12 col-xxl-6">
        <section class="card border-0 shadow-sm rounded-5 overflow-hidden h-100" data-list-search-scope>
            <div class="card-body p-4 p-lg-4 border-bottom">
                <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
                    <div>
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="badge rounded-pill text-bg-success-subtle text-success-emphasis px-3">Clients confirmes</span>
                            <span class="badge rounded-pill text-bg-light px-3">{{ counters.confirmed }}</span>
                        </div>
                        <h2 class="h4 mb-1">Clients valides</h2>
                        <p class="text-body-secondary mb-0">Affiche les clients deja confirmes pour garder une lecture claire du portefeuille actif.</p>
                    </div>
                    <a href="{{ path('app_client_new') }}" class="btn btn-outline-primary" data-crud-modal-url="{{ path('app_client_new') }}">
                        <i class="bi bi-person-plus me-2"></i>Ajouter un client
                    </a>
                </div>
            </div>
            {% include '_partials/_listing_search.html.twig' with { placeholder: 'Rechercher dans les clients confirmes...', target: 'tbody tr' } %}
            <div class="card-body p-0">
                {% include 'client/_list.html.twig' with {
                    clients: groupedClients.confirmed,
                    empty_message: 'Aucun client confirme pour le moment.'
                } %}
            </div>
        </section>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-5 mt-4 overflow-hidden">
    <div class="card-body p-4 p-lg-4 d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
        <div>
            <div class="d-flex align-items-center gap-2 mb-2">
                <span class="badge rounded-pill text-bg-danger px-3">Clients refuses</span>
                <span class="badge rounded-pill text-bg-light px-3">{{ counters.refused }}</span>
            </div>
            <h2 class="h5 mb-1">Acces lecture seule aux clients refuses</h2>
            <p class="text-body-secondary mb-0">Consulte la liste des clients refuses sans pouvoir modifier leur fiche ni leur statut.</p>
        </div>
        <a href="{{ path('app_client_refused_index') }}" class="btn btn-outline-danger">
            <i class="bi bi-eye me-2"></i>Voir les refuses
        </a>
    </div>
</div>
