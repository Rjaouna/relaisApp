{% extends 'base.html.twig' %}

{% block title %}Detail consultation fournisseur{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <div class="text-body-secondary small text-uppercase mb-2">Consultation fournisseur</div>
            <h1 class="h2 mb-0">{{ consultation.needTitle }}</h1>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('app_supplier_consultation_index') }}" class="btn btn-outline-secondary rounded-pill px-4"><i class="bi bi-arrow-left me-2"></i>Retour</a>
            <a href="{{ path('app_supplier_consultation_edit', {id: consultation.id}) }}" class="btn btn-primary rounded-pill px-4" data-crud-modal-url="{{ path('app_supplier_consultation_edit', {id: consultation.id}) }}">Modifier</a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-5">
                <div class="card-body p-4">
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <span class="badge rounded-pill text-bg-light">{{ consultation.status|replace({'_': ' '})|title }}</span>
                        <span class="badge rounded-pill {{ consultation.sampleStatus == 'non_conforme' ? 'text-bg-danger' : 'text-bg-light' }}">{{ consultation.sampleStatus|replace({'_': ' '})|title }}</span>
                        {% if consultation.selectedSupplier %}
                            <span class="badge rounded-pill text-bg-success">Fournisseur retenu</span>
                        {% endif %}
                    </div>
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Fournisseur</dt>
                        <dd class="col-sm-8">
                            {% if consultation.supplier %}
                                <a class="text-decoration-none" href="{{ path('app_supplier_show', {id: consultation.supplier.id}) }}">{{ consultation.supplier.name }}</a>
                            {% else %}
                                Non renseigne
                            {% endif %}
                        </dd>
                        <dt class="col-sm-4">Delai attendu</dt>
                        <dd class="col-sm-8">{{ consultation.expectedDelay ?: 'Non renseigne' }}</dd>
                        <dt class="col-sm-4">Montant devis</dt>
                        <dd class="col-sm-8">{{ consultation.quotedAmount ? consultation.quotedAmount ~ ' MAD' : 'Non renseigne' }}</dd>
                        <dt class="col-sm-4">Montant negocie</dt>
                        <dd class="col-sm-8">{{ consultation.negotiatedAmount ? consultation.negotiatedAmount ~ ' MAD' : 'Non renseigne' }}</dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-5 h-100">
                <div class="card-header bg-white border-0 pt-4 px-4">Points de controle</div>
                <div class="card-body pt-0">
                    <div class="mb-3">
                        <div class="small text-uppercase text-body-secondary mb-2">Specification</div>
                        <div>{{ consultation.needDetails }}</div>
                    </div>
                    <div class="mb-3">
                        <div class="small text-uppercase text-body-secondary mb-2">Conformite</div>
                        <div>{{ consultation.complianceNotes ?: 'Aucune note de conformite.' }}</div>
                    </div>
                    <div>
                        <div class="small text-uppercase text-body-secondary mb-2">Negociation</div>
                        <div>{{ consultation.negotiationNotes ?: 'Aucune note de negociation.' }}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
