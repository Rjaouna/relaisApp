{% extends 'base.html.twig' %}

{% block title %}Utilisateur{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <div class="text-body-secondary small text-uppercase mb-2">Compte utilisateur</div>
            <h1 class="h2 mb-1">{{ user.fullName }}</h1>
            <p class="text-body-secondary mb-0">{{ user.email }}</p>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('app_user_index') }}" class="btn btn-outline-secondary px-4"><i class="bi bi-arrow-left me-2"></i>Retour</a>
            <a href="{{ path('app_user_edit', {id: user.id}) }}" class="btn btn-primary px-4" data-crud-modal-url="{{ path('app_user_edit', {id: user.id}) }}">Modifier</a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 rounded-5">
                <div class="card-body p-4">
                    <div class="d-flex gap-2 mb-3 flex-wrap">
                        <span class="badge rounded-pill text-bg-light">{{ user.roleLabels ?: 'ROLE_USER' }}</span>
                        <span class="badge rounded-pill {{ user.isActive ? 'text-bg-success' : 'text-bg-secondary' }}">{{ user.isActive ? 'Actif' : 'Inactif' }}</span>
                    </div>
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Nom</dt>
                        <dd class="col-sm-8">{{ user.fullName }}</dd>
                        <dt class="col-sm-4">Email</dt>
                        <dd class="col-sm-8">{{ user.email }}</dd>
                        <dt class="col-sm-4">Roles</dt>
                        <dd class="col-sm-8">{{ user.roleLabels ?: 'ROLE_USER' }}</dd>
                        <dt class="col-sm-4">Etat</dt>
                        <dd class="col-sm-8">{{ user.isActive ? 'Actif' : 'Inactif' }}</dd>
                        <dt class="col-sm-4">Commercial lie</dt>
                        <dd class="col-sm-8">{{ user.commercial ? user.commercial.fullName : 'Aucun' }}</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
