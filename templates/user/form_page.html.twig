{% extends 'base.html.twig' %}

{% block title %}{{ userEntity.id ? 'Modifier l utilisateur' : 'Ajouter un utilisateur' }}{% endblock %}

{% block body %}
    <div class="card border-0 rounded-5">
        <div class="card-body p-4 p-lg-5">
            <h1 class="h3 mb-4">{{ userEntity.id ? 'Modifier l utilisateur' : 'Ajouter un utilisateur' }}</h1>
            {{ form_start(form) }}
                <div class="row g-3">
                    <div class="col-md-6">{{ form_row(form.fullName) }}</div>
                    <div class="col-md-6">{{ form_row(form.email) }}</div>
                    <div class="col-12">
                        <label class="form-label fw-semibold mb-3">{{ form.roles.vars.label }}</label>
                        <div class="row g-2">
                            {% for child in form.roles %}
                                <div class="col-md-6">
                                    <div class="form-check border rounded-4 px-3 py-3 bg-white">
                                        {{ form_widget(child, { attr: { class: 'form-check-input' } }) }}
                                        {{ form_label(child, null, { label_attr: { class: 'form-check-label fw-semibold ms-2' } }) }}
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                        {{ form_errors(form.roles) }}
                    </div>
                    <div class="col-md-6">{{ form_row(form.isActive) }}</div>
                    <div class="col-md-6">{{ form_row(form.plainPassword) }}</div>
                </div>
                <div class="d-flex gap-2 mt-4">
                    <a href="{{ path('app_user_index') }}" class="btn btn-outline-secondary">Annuler</a>
                    <button type="submit" class="btn btn-primary">Enregistrer</button>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
