{% extends 'base.html.twig' %}

{% block title %}Detail ville{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <div class="text-body-secondary small text-uppercase mb-2">Fiche ville</div>
            <h1 class="h2 mb-0">{{ city.name }}</h1>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('app_city_index') }}" class="btn btn-outline-secondary rounded-pill px-4"><i class="bi bi-arrow-left me-2"></i>Retour</a>
            <a href="{{ path('app_city_edit', {id: city.id}) }}" class="btn btn-primary rounded-pill px-4" data-crud-modal-url="{{ path('app_city_edit', {id: city.id}) }}">Modifier</a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-5">
        <div class="card-body p-4">
            <dl class="row mb-0">
                <dt class="col-sm-4">Statut</dt>
                <dd class="col-sm-8">{{ city.isActive ? 'Active' : 'Inactive' }}</dd>
                <dt class="col-sm-4">Zones rattachees</dt>
                <dd class="col-sm-8">{{ city.zonesCount }}</dd>
            </dl>
        </div>
    </div>
{% endblock %}
