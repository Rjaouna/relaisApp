{% if readyToCloseTours is not empty %}
    <div class="card border-0 shadow-sm rounded-5 overflow-hidden">
        <div class="card-body p-3 p-lg-4">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-3">
                <div>
                    <div class="app-section-kicker text-warning mb-2">Notification terrain</div>
                    <h2 class="h5 mb-1">Tournées prêtes pour demande de clôture</h2>
                    <p class="text-body-secondary mb-0 small">Certaines tournées sont terminées mais attendent encore votre demande de clôture.</p>
                </div>
                <span class="badge rounded-pill text-bg-warning">{{ readyToCloseTours|length }} a finaliser</span>
            </div>

            <div class="d-flex flex-column gap-2">
                {% for tour in readyToCloseTours %}
                    <a href="{{ path('app_tour_show', {id: tour.id}) }}" class="card border-0 bg-body-tertiary rounded-4 text-reset text-decoration-none">
                        <div class="card-body p-3 d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-center">
                            <div>
                                <div class="fw-semibold">{{ tour.name }}</div>
                                <div class="small text-body-secondary">{{ tour.city }} · {{ tour.completedVisits }}/{{ tour.plannedVisits }} client(s) traites</div>
                            </div>
                            <span class="btn btn-sm btn-outline-warning rounded-pill">Demander la clôture</span>
                        </div>
                    </a>
                {% endfor %}
            </div>
        </div>
    </div>
{% endif %}
