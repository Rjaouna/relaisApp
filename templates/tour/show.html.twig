{% extends 'base.html.twig' %}

{% block title %}Detail tournee{% endblock %}

{% macro visit_row_link(visit, tour, commercial_mode, admin_review_mode, closure_requested) %}
    {% if commercial_mode %}
        {{ path('app_visit_outcome', {id: visit.id, tour: tour.id}) }}
    {% elseif admin_review_mode and closure_requested and visit.result %}
        {{ path('app_visit_review', {id: visit.id, tour: tour.id}) }}
    {% else %}
        {{ path('app_visit_show', {id: visit.id}) }}
    {% endif %}
{% endmacro %}

{% macro waze_icon() %}
    <svg class="app-icon-waze" viewBox="0 0 64 64" aria-hidden="true" focusable="false">
        <path fill="currentColor" d="M32 8c-12.7 0-23 9.4-23 21 0 6.1 2.9 11.6 7.6 15.4 1.4 1.1 2.4 2.8 2.7 4.6l.5 2.7c.2 1.2 1.3 2 2.5 2h2.4c1.1 0 2-.7 2.4-1.7l.7-2.1h7l.7 2.1c.3 1 1.3 1.7 2.4 1.7h2.4c1.2 0 2.3-.8 2.5-2l.5-2.7c.3-1.8 1.3-3.5 2.7-4.6C52.1 40.6 55 35.1 55 29c0-11.6-10.3-21-23-21Zm-9.4 22.8a3.5 3.5 0 1 1 0-7 3.5 3.5 0 0 1 0 7Zm18.8 0a3.5 3.5 0 1 1 0-7 3.5 3.5 0 0 1 0 7Z"/>
        <path fill="currentColor" d="M24.2 52.8a4.2 4.2 0 1 0 8.4 0h-8.4Zm10.2 0a4.2 4.2 0 1 0 8.4 0h-8.4Z"/>
    </svg>
{% endmacro %}

{% block body %}
    {% import _self as view %}
    {% set commercial_mode = is_granted('ROLE_COMMERCIAL') and not is_granted('ROLE_ADMIN') and not is_granted('ROLE_DIRECTION') %}
    {% set admin_review_mode = is_granted('ROLE_ADMIN') or is_granted('ROLE_DIRECTION') %}
    {% set is_new_tour = tour.status == constant('App\\Entity\\Tour::STATUS_PROGRAMMED') and tour.completedVisits == 0 %}
    {% set closure_requested = tour.closureRequestedAt %}
    {% set review_pending = reviewSummary.pending > 0 %}
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
        <div>
            <div class="text-body-secondary small text-uppercase mb-2">{{ commercial_mode ? 'Tournee terrain' : 'Detail tournee' }}</div>
            <div class="d-flex flex-wrap align-items-center gap-2">
                <h1 class="h2 mb-0">{{ tour.name }}</h1>
                {% if is_new_tour %}
                    <span class="badge rounded-pill text-bg-primary">New</span>
                {% endif %}
            </div>
        </div>
        <div class="app-mobile-actions justify-content-start justify-content-lg-end">
            {% if commercial_mode and tour.status != constant('App\\Entity\\Tour::STATUS_COMPLETED') and tour.status != constant('App\\Entity\\Tour::STATUS_CANCELLED') %}
                {% if not closure_requested %}
                    <button type="button" class="btn btn-primary rounded-pill px-4" data-crud-post-url="{{ path('app_tour_request_close', {id: tour.id}) }}" data-crud-reload="true">
                        <i class="bi bi-send-check me-2"></i>Demander la fermeture
                    </button>
                {% else %}
                    <button type="button" class="btn btn-outline-warning rounded-pill px-4" disabled>
                        <i class="bi bi-hourglass-split me-2"></i>Controle admin en attente
                    </button>
                {% endif %}
            {% elseif admin_review_mode and closure_requested and tour.status != constant('App\\Entity\\Tour::STATUS_COMPLETED') %}
                {% if review_pending %}
                    <a href="#tour-review-section" class="btn btn-warning rounded-pill px-4">
                        <i class="bi bi-clipboard-check me-2"></i>Controler les visites
                    </a>
                {% else %}
                    <button type="button" class="btn btn-success rounded-pill px-4" data-crud-post-url="{{ path('app_tour_close', {id: tour.id}) }}" data-crud-reload="true">
                        <i class="bi bi-shield-check me-2"></i>Cloturer apres controle
                    </button>
                {% endif %}
            {% endif %}
            <a href="{{ path('app_tour_index') }}" class="btn btn-outline-secondary rounded-pill px-4"><i class="bi bi-arrow-left me-2"></i>Retour</a>
        </div>
    </div>
    {% if admin_review_mode and closure_requested %}
        <div class="alert alert-primary border-0 rounded-5 shadow-sm mb-4">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                <div>
                    <div class="fw-semibold mb-1">Controle administratif de la tournee</div>
                    <div class="small">Verifie les visites du commercial puis valide ou rejette chaque compte rendu avec un commentaire.</div>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <span class="badge rounded-pill text-bg-warning">{{ reviewSummary.pending }} en attente</span>
                    <span class="badge rounded-pill text-bg-success">{{ reviewSummary.validated }} validee(s)</span>
                    <span class="badge rounded-pill text-bg-danger">{{ reviewSummary.rejected }} rejetee(s)</span>
                    {% if review_pending %}
                        <button type="button" class="btn btn-sm btn-success rounded-pill" data-crud-post-url="{{ path('app_tour_review_all', {id: tour.id}) }}" data-crud-reload="true" data-crud-confirm="Valider toutes les visites en attente sur cette tournee ?">
                            <i class="bi bi-check2-all me-2"></i>Valider toutes les visites
                        </button>
                        <a href="#tour-review-section" class="btn btn-sm btn-warning rounded-pill">
                            <i class="bi bi-clipboard-check me-2"></i>Ouvrir le controle
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>
    {% endif %}
    {% if closure_requested and tour.status != constant('App\\Entity\\Tour::STATUS_COMPLETED') %}
        <div class="alert {{ review_pending ? 'alert-warning' : 'alert-success' }} border-0 rounded-5 shadow-sm mb-4">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                <div>
                    <div class="fw-semibold mb-1">{{ review_pending ? 'Controle administratif en attente' : 'Controle termine - cloture possible' }}</div>
                    <div class="small">
                        Demande envoyee le {{ closure_requested|date('d/m/Y H:i') }}.
                        {% if review_pending %}
                            L administration doit encore controler les visites avant la cloture finale.
                        {% else %}
                            Toutes les visites sont controlees. L administration peut maintenant cloturer la tournee.
                        {% endif %}
                    </div>
                </div>
                {% if admin_review_mode and not review_pending %}
                    <button type="button" class="btn btn-success rounded-pill px-4" data-crud-post-url="{{ path('app_tour_close', {id: tour.id}) }}" data-crud-reload="true">
                        <i class="bi bi-shield-check me-2"></i>Valider la cloture
                    </button>
                {% endif %}
            </div>
        </div>
    {% endif %}
    {% set header_status_badge = 'text-bg-light' %}
    {% if tour.status == constant('App\\Entity\\Tour::STATUS_COMPLETED') %}
        {% set header_status_badge = 'text-bg-success' %}
    {% elseif review_pending %}
        {% set header_status_badge = 'text-bg-warning' %}
    {% elseif tour.status == constant('App\\Entity\\Tour::STATUS_IN_PROGRESS') %}
        {% set header_status_badge = 'text-bg-primary' %}
    {% elseif tour.status == constant('App\\Entity\\Tour::STATUS_CANCELLED') %}
        {% set header_status_badge = 'text-bg-secondary' %}
    {% endif %}

    <div class="card border-0 shadow-sm rounded-5 mb-4" id="tour-review-section">
        <div class="card-body p-4">
            <div class="app-tour-header-grid">
                <div>
                    <div class="app-mobile-meta-label">Ville</div>
                    <div class="h5 mb-0">{{ tour.city }}</div>
                </div>
                <div>
                    <div class="app-mobile-meta-label">Zone</div>
                    <div class="h5 mb-0">{{ tour.zone ? tour.zone.name : 'Zone non renseignee' }}</div>
                </div>
                <div>
                    <div class="app-mobile-meta-label">Statut</div>
                    <div><span class="badge rounded-pill {{ header_status_badge }}">{{ review_pending ? 'Controle admin' : tour.status|replace({'_': ' '})|title }}</span></div>
                </div>
                <div>
                    <div class="app-mobile-meta-label">Avancement</div>
                    <div class="fw-semibold mb-2">{{ tour.completedVisits }}/{{ tour.plannedVisits }}</div>
                    <div class="progress" style="height: 0.5rem;">
                        <div class="progress-bar" style="width: {{ tour.plannedVisits > 0 ? (tour.completedVisits / tour.plannedVisits * 100) : 0 }}%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-5 h-100">
        <div class="card-header bg-white border-0 pt-4 px-4">
            <h2 class="h5 mb-0">{{ commercial_mode ? 'Clients de la tournee' : 'Clients affectes a la tournee' }}</h2>
        </div>
        <div class="card-body p-0">
                    <div class="d-md-none p-3 d-flex flex-column gap-3" data-tour-sort-group>
                        {% for visit in visits %}
                            {% set is_refused_client = visit.client.status == constant('App\\Entity\\Client::STATUS_REFUSED') %}
                            {% set is_new_visit = visit.status == constant('App\\Entity\\Visit::STATUS_PLANNED') and not visit.result %}
                            <article class="app-mobile-card app-tour-stop-card {{ is_refused_client ? 'app-mobile-card-warning' : '' }}" data-tour-stop data-destination="{{ [visit.client.address, visit.client.city]|filter(v => v)|join(', ')|e('html_attr') }}" data-client-name="{{ visit.client.name|e('html_attr') }}" data-latitude="{{ visit.client.latitude|default('')|e('html_attr') }}" data-longitude="{{ visit.client.longitude|default('')|e('html_attr') }}">
                                <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                                    <div class="min-w-0">
                                        <div class="d-flex flex-wrap align-items-center gap-2">
                                            <a href="{{ view.visit_row_link(visit, tour, commercial_mode, admin_review_mode, closure_requested) }}" class="fw-semibold app-quick-link d-flex flex-wrap align-items-center gap-2">
                                                <span>{{ visit.client.name }}</span>
                                                {% if is_new_visit %}
                                                    <span class="badge rounded-pill text-bg-primary">New</span>
                                                {% endif %}
                                            </a>
                                        </div>
                                        <div class="text-body-secondary small">{{ visit.client.city }}</div>
                                    </div>
                                    <a href="https://www.waze.com/ul?q={{ [visit.client.address, visit.client.city]|filter(v => v)|join(', ')|url_encode }}&navigate=yes" target="_blank" rel="noopener" class="btn btn-sm app-btn-waze rounded-pill px-3 flex-shrink-0" aria-label="Ouvrir Waze pour {{ visit.client.name }}" title="Ouvrir Waze pour {{ visit.client.name }}">
                                        Waze
                                    </a>
                                    {% if is_refused_client %}
                                        <span class="badge rounded-pill text-bg-danger">Client refuse</span>
                                    {% endif %}
                                </div>
                                <div class="app-mobile-meta-grid mb-3">
                                    <div>
                                        <div class="app-mobile-meta-label">Heure</div>
                                        <div>{{ visit.scheduledAt|date('H:i') }}</div>
                                    </div>
                                    <div>
                                        <div class="app-mobile-meta-label">Distance</div>
                                        <div><span class="badge rounded-pill text-bg-light" data-distance-badge>Calcul...</span></div>
                                    </div>
                                    <div>
                                        <div class="app-mobile-meta-label">Type</div>
                                        <div>{{ visit.type|replace({'_': ' '})|title }}</div>
                                    </div>
                                    <div class="app-mobile-meta-span">
                                        <div class="app-mobile-meta-label">Acces rapide</div>
                                        <div class="small text-body-secondary">Touchez la fiche pour ouvrir la visite.</div>
                                    </div>
                                </div>
                            </article>
                        {% else %}
                            <div class="text-center py-4 text-body-secondary">Aucun client planifie sur cette tournee.</div>
                        {% endfor %}
                    </div>
                    <div class="table-responsive d-none d-md-block">
                        <table class="table table-hover align-middle mb-0" data-tour-table>
                            <thead class="table-light">
                                <tr>
                                    <th>Client</th>
                                    <th>Heure</th>
                                    <th>Distance</th>
                                    <th>Type</th>
                                </tr>
                            </thead>
                            <tbody data-tour-sort-group>
                                {% for visit in visits %}
                                    {% set is_refused_client = visit.client.status == constant('App\\Entity\\Client::STATUS_REFUSED') %}
                                    {% set is_new_visit = visit.status == constant('App\\Entity\\Visit::STATUS_PLANNED') and not visit.result %}
                                    <tr class="{{ is_refused_client ? 'table-danger' : '' }}" data-tour-stop data-destination="{{ [visit.client.address, visit.client.city]|filter(v => v)|join(', ')|e('html_attr') }}" data-client-name="{{ visit.client.name|e('html_attr') }}" data-latitude="{{ visit.client.latitude|default('')|e('html_attr') }}" data-longitude="{{ visit.client.longitude|default('')|e('html_attr') }}">
                                        <td>
                                            <div class="d-flex justify-content-between align-items-start gap-3">
                                                <div class="fw-semibold d-flex flex-wrap align-items-center gap-2">
                                                    <a href="{{ view.visit_row_link(visit, tour, commercial_mode, admin_review_mode, closure_requested) }}" class="app-quick-link">{{ visit.client.name }}</a>
                                                    {% if is_new_visit %}
                                                        <span class="badge rounded-pill text-bg-primary">New</span>
                                                    {% endif %}
                                                    {% if is_refused_client %}
                                                        <span class="badge rounded-pill text-bg-danger">
                                                            <i class="bi bi-exclamation-triangle-fill me-1"></i>Client refuse
                                                        </span>
                                                    {% endif %}
                                                </div>
                                                <a href="https://www.waze.com/ul?q={{ [visit.client.address, visit.client.city]|filter(v => v)|join(', ')|url_encode }}&navigate=yes" target="_blank" rel="noopener" class="btn btn-sm app-btn-waze rounded-pill px-3 flex-shrink-0" aria-label="Ouvrir Waze pour {{ visit.client.name }}" title="Ouvrir Waze pour {{ visit.client.name }}">
                                                    Waze
                                                </a>
                                            </div>
                                            <div class="text-body-secondary small">{{ visit.client.city }}</div>
                                        </td>
                                        <td>{{ visit.scheduledAt|date('H:i') }}</td>
                                        <td><span class="badge rounded-pill text-bg-light" data-distance-badge>Calcul...</span></td>
                                        <td><span class="badge rounded-pill text-bg-light">{{ visit.type|replace({'_': ' '})|title }}</span></td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="4" class="text-center py-4 text-body-secondary">Aucun client planifie sur cette tournee.</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
        </div>
    </div>
{% endblock %}
