<div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>Periode</th>
                <th>Commercial</th>
                <th>CA</th>
                <th>Visites</th>
                <th>Nvx clients valides</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for objective in objectives %}
                <tr>
                    <td>
                        <a class="fw-semibold text-decoration-none app-quick-link" href="{{ path('app_objective_show', {id: objective.id}) }}">{{ objective.periodLabel }}</a>
                    </td>
                    <td>
                        <a class="text-decoration-none app-quick-link fw-semibold" href="{{ path('app_commercial_show', {id: objective.commercial.id}) }}">{{ objective.commercial.fullName }}</a>
                    </td>
                    <td>
                        <div class="fw-semibold">{{ objective.salesActual }}/{{ objective.salesTarget }}</div>
                        <div class="progress mt-2" style="height: 0.4rem;">
                            <div class="progress-bar" style="width: {{ objective.salesTarget > 0 ? (objective.salesActual / objective.salesTarget * 100) : 0 }}%"></div>
                        </div>
                    </td>
                    <td>
                        <div class="fw-semibold">{{ objective.visitsActual }}/{{ objective.visitsTarget }}</div>
                        <div class="small text-body-secondary">Nvx clients {{ objective.newClientsActual }}/{{ objective.newClientsTarget }}</div>
                    </td>
                    <td>
                        <span class="badge rounded-pill text-bg-light">{{ objective.newClientsActual }} valide(s)</span>
                    </td>
                    <td class="text-end">
                        <a href="{{ path('app_objective_show', {id: objective.id}) }}" class="btn btn-outline-secondary btn-sm rounded-pill">Consulter</a>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="6" class="text-center py-4 text-body-secondary">Aucun objectif disponible.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
