{% extends 'base.html.twig' %}

{% block title %}Detail livraison{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <div class="text-body-secondary small text-uppercase mb-2">Dossier livraison</div>
            <h1 class="h2 mb-0">{{ delivery.reference }}</h1>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('app_delivery_index') }}" class="btn btn-outline-secondary rounded-pill px-4"><i class="bi bi-arrow-left me-2"></i>Retour</a>
            <a href="{{ path('app_delivery_edit', {id: delivery.id}) }}" class="btn btn-primary rounded-pill px-4" data-crud-modal-url="{{ path('app_delivery_edit', {id: delivery.id}) }}">Modifier</a>
        </div>
    </div>
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-5">
                <div class="card-body p-4">
                    <div class="d-flex gap-2 mb-3">
                        <span class="badge rounded-pill text-bg-light">{{ delivery.city }}</span>
                        <span class="badge rounded-pill text-bg-light">{{ delivery.status|replace({'_': ' '})|title }}</span>
                    </div>
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Client</dt>
                        <dd class="col-sm-8">{{ delivery.client.name }}</dd>
                        <dt class="col-sm-4">Date prevue</dt>
                        <dd class="col-sm-8">{{ delivery.scheduledAt|date('d/m/Y H:i') }}</dd>
                        <dt class="col-sm-4">Retard estime</dt>
                        <dd class="col-sm-8">{{ delivery.delayDays }} jour(s)</dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-5 h-100">
                <div class="card-body p-4">
                    <div class="text-body-secondary small text-uppercase mb-2">Suivi</div>
                    <div class="display-6 fw-semibold">{{ delivery.delayDays }}</div>
                    <div class="text-body-secondary">jour(s) de decalage</div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
