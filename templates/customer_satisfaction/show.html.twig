{% extends 'base.html.twig' %}

{% block title %}Detail satisfaction client{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <div class="text-body-secondary small text-uppercase mb-2">Satisfaction client</div>
            <h1 class="h2 mb-0">{{ satisfaction.client.name }}</h1>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('app_customer_satisfaction_index') }}" class="btn btn-outline-secondary rounded-pill px-4"><i class="bi bi-arrow-left me-2"></i>Retour</a>
            <a href="{{ path('app_customer_satisfaction_edit', {id: satisfaction.id}) }}" class="btn btn-primary rounded-pill px-4" data-crud-modal-url="{{ path('app_customer_satisfaction_edit', {id: satisfaction.id}) }}">Modifier</a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-5 h-100">
                <div class="card-body p-4">
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <span class="badge rounded-pill {{ satisfaction.satisfactionLevel == 'eleve' ? 'text-bg-success' : (satisfaction.satisfactionLevel == 'moyen' ? 'text-bg-warning' : 'text-bg-danger') }}">{{ satisfaction.satisfactionLevel|title }}</span>
                        <span class="badge rounded-pill text-bg-light">{{ satisfaction.status|replace({'_': ' '})|title }}</span>
                    </div>
                    <dl class="row mb-0">
                        <dt class="col-sm-5">Client</dt>
                        <dd class="col-sm-7"><a class="text-decoration-none" href="{{ path('app_client_show', {id: satisfaction.client.id}) }}">{{ satisfaction.client.name }}</a></dd>
                        <dt class="col-sm-5">Livraison souhaitee</dt>
                        <dd class="col-sm-7">{{ satisfaction.deliveryRequestedAt ? satisfaction.deliveryRequestedAt|date('d/m/Y') : 'Non renseignee' }}</dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-5">
                <div class="card-body p-4">
                    <div class="small text-uppercase text-body-secondary mb-2">Attentes / ressenti</div>
                    <p class="mb-4">{{ satisfaction.expectationSummary ?: 'Aucun retour de satisfaction renseigne.' }}</p>
                    <div class="small text-uppercase text-body-secondary mb-2">Ecoute marche</div>
                    <p class="mb-4">{{ satisfaction.marketListening ?: 'Aucune ecoute marche formalisee.' }}</p>
                    <div class="small text-uppercase text-body-secondary mb-2">Prochaine action</div>
                    <p class="mb-0">{{ satisfaction.nextAction ?: 'Aucune prochaine action definie.' }}</p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
