{% extends 'base.html.twig' %}

{% block title %}Satisfaction clients{% endblock %}

{% block body %}
    <div class="card border-0 shadow-sm rounded-5 mb-4">
        <div class="card-body p-4 p-lg-5">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <span class="badge rounded-pill text-bg-primary-subtle text-primary-emphasis mb-3">Relation client</span>
                    <h1 class="h3 mb-1">Satisfaction clients</h1>
                    <p class="text-body-secondary mb-0">Suivez l'ecoute client, les attentes, la date de livraison souhaitee et les prochaines actions de fidelisation.</p>
                </div>
                <a href="{{ path('app_customer_satisfaction_new') }}" class="btn btn-primary rounded-pill px-4" data-crud-modal-url="{{ path('app_customer_satisfaction_new') }}"><i class="bi bi-plus-lg me-2"></i>Ajouter</a>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-5 overflow-hidden" data-list-search-scope>
        {% include '_partials/_listing_search.html.twig' with { placeholder: 'Rechercher un client, un niveau de satisfaction ou un statut...' } %}
        <div class="card-body p-0" data-crud-list>
            {% include 'customer_satisfaction/_list.html.twig' with { satisfactions: satisfactions } %}
        </div>
    </div>
{% endblock %}
