{% extends 'base.html.twig' %}

{% block title %}Marche{% endblock %}

{% block body %}
    <div class="card border-0 shadow-sm rounded-5 mb-4">
        <div class="card-body p-4 p-lg-5">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <span class="badge rounded-pill text-bg-primary-subtle text-primary-emphasis mb-3">BI Marche</span>
                    <h1 class="h3 mb-1">Analyse du marche</h1>
                    <p class="text-body-secondary mb-0">Reperez les zones saturees, les poches de croissance et les villes a developper a partir des donnees reelles de l'application.</p>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <form method="post" action="{{ path('app_market_recalculate') }}">
                        <button class="btn btn-outline-primary rounded-pill px-4" type="submit"><i class="bi bi-arrow-repeat me-2"></i>Recalculer les indicateurs</button>
                    </form>
                    <a href="{{ path('app_market_new') }}" class="btn btn-primary rounded-pill px-4" data-crud-modal-url="{{ path('app_market_new') }}"><i class="bi bi-plus-lg me-2"></i>Ajouter une ville</a>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-5 overflow-hidden" data-list-search-scope>
        {% include '_partials/_listing_search.html.twig' with { placeholder: 'Rechercher une ville ou un statut de zone...' } %}
        <div class="card-body p-0" data-crud-list>
            {% include 'market/_list.html.twig' with { markets: markets } %}
        </div>
    </div>
{% endblock %}
