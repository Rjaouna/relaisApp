{% extends 'base.html.twig' %}

{% block title %}Detail fournisseur{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <div class="text-body-secondary small text-uppercase mb-2">Fiche fournisseur</div>
            <h1 class="h2 mb-0">{{ supplier.name }}</h1>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('app_supplier_index') }}" class="btn btn-outline-secondary rounded-pill px-4"><i class="bi bi-arrow-left me-2"></i>Retour</a>
            <a href="{{ path('app_supplier_edit', {id: supplier.id}) }}" class="btn btn-primary rounded-pill px-4" data-crud-modal-url="{{ path('app_supplier_edit', {id: supplier.id}) }}">Modifier</a>
        </div>
    </div>
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-5">
                <div class="card-body p-4">
                    <div class="d-flex gap-2 mb-3">
                        <span class="badge rounded-pill text-bg-light">{{ supplier.country }}</span>
                        <span class="badge rounded-pill text-bg-light">{{ supplier.status|replace({'_': ' '})|title }}</span>
                    </div>
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Email</dt>
                        <dd class="col-sm-8">{{ supplier.contactEmail ?: 'Non renseigne' }}</dd>
                        <dt class="col-sm-4">Reactivite</dt>
                        <dd class="col-sm-8">{{ supplier.reactivityScore }}/100</dd>
                        <dt class="col-sm-4">Competitivite prix</dt>
                        <dd class="col-sm-8">{{ supplier.priceScore }}/100</dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-5 h-100">
                <div class="card-header bg-white border-0 pt-4 px-4">Notes</div>
                <div class="card-body pt-0">
                    {{ supplier.notes ?: 'Aucune note fournisseur.' }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
