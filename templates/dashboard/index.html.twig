{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}
    <section class="d-flex flex-column gap-3" data-dashboard-charts
        data-dashboard-tours='{{ dashboardStats.charts.tours_by_status|json_encode|e('html_attr') }}'
        data-dashboard-activity='{{ dashboardStats.charts.monthly_activity|json_encode|e('html_attr') }}'
        data-dashboard-revenue='{{ dashboardStats.charts.monthly_revenue|json_encode|e('html_attr') }}'
        data-dashboard-commercials='{{ dashboardStats.charts.visits_by_commercial|json_encode|e('html_attr') }}'>
        <div data-dashboard-pending-closures-url="{{ path('app_dashboard_pending_closures') }}">
            {% include 'dashboard/_pending_closures.html.twig' with { pendingClosureTours: overview.pending_closure_tours } %}
        </div>

        <div class="app-dashboard-shell rounded-5 p-3 p-lg-4 p-xxl-5">
            <div class="row g-3 g-xl-4 align-items-stretch">
                <div class="col-12 col-xl-8">
                    <div class="app-dashboard-hero rounded-5 p-3 p-lg-4 h-100">
                        <div class="position-relative h-100 d-flex flex-column">
                            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-start gap-3 mb-4">
                                <div>
                                    <div class="app-section-kicker app-section-kicker-dark mb-2">Vue direction</div>
                                    <h1 class="app-dashboard-title mb-2">Cockpit commercial</h1>
                                    <p class="app-dashboard-subtitle mb-0">Suivez la traction terrain, les relances, les tournees et le revenu depuis un meme espace de pilotage.</p>
                                </div>
                                <div class="app-dashboard-hero-actions d-grid gap-2">
                                    <form method="post" action="{{ path('app_dashboard_generate_tours') }}">
                                        <button class="btn btn-primary px-4 w-100" type="submit"><i class="bi bi-signpost-split me-2"></i>Generer les tournees</button>
                                    </form>
                                    <div class="d-grid gap-2 d-sm-flex">
                                        <form method="post" action="{{ path('app_dashboard_assign_clients') }}" class="flex-fill">
                                            <button class="btn btn-light w-100" type="submit"><i class="bi bi-diagram-3 me-2"></i>Affecter</button>
                                        </form>
                                        <form method="post" action="{{ path('app_dashboard_rebuild_markets') }}" class="flex-fill">
                                            <button class="btn btn-outline-light w-100" type="submit"><i class="bi bi-arrow-repeat me-2"></i>Recalcul</button>
                                        </form>
                                    </div>
                                </div>
                            </div>

                            <div class="row g-3 mt-auto">
                                <div class="col-sm-6 col-lg-3">
                                    <div class="app-dashboard-highlight rounded-4 p-3 h-100">
                                        <div class="small text-white-50 mb-1">Clients actifs</div>
                                        <div class="h3 fw-bold mb-0">{{ overview.clients_active }}</div>
                                    </div>
                                </div>
                                <div class="col-sm-6 col-lg-3">
                                    <div class="app-dashboard-highlight rounded-4 p-3 h-100">
                                        <div class="small text-white-50 mb-1">Prospects</div>
                                        <div class="h3 fw-bold mb-0">{{ overview.prospects }}</div>
                                    </div>
                                </div>
                                <div class="col-sm-6 col-lg-3">
                                    <div class="app-dashboard-highlight rounded-4 p-3 h-100">
                                        <div class="small text-white-50 mb-1">Tournees a controler</div>
                                        <div class="h3 fw-bold mb-0">{{ overview.pending_closure_tours|length }}</div>
                                    </div>
                                </div>
                                <div class="col-sm-6 col-lg-3">
                                    <div class="app-dashboard-highlight rounded-4 p-3 h-100">
                                        <div class="small text-white-50 mb-1">CA du mois</div>
                                        <div class="h4 fw-bold mb-0">{{ overview.revenue|number_format(0, ',', ' ') }} MAD</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-xl-4">
                    <div class="app-dashboard-sidepanel rounded-5 p-3 p-lg-4 h-100">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <div>
                                <div class="app-section-kicker text-secondary mb-2">Lecture instantanee</div>
                                <h2 class="h4 mb-1">Etat general</h2>
                                <p class="text-body-secondary small mb-0">Les signaux a surveiller maintenant.</p>
                            </div>
                            <a href="{{ path('app_stats_index') }}" class="btn btn-outline-primary px-3">Stat</a>
                        </div>

                        <div class="d-flex flex-column gap-3">
                            <a href="{{ path('app_visit_index') }}" class="app-dashboard-mini-card text-reset">
                                <span class="app-dashboard-mini-icon"><i class="bi bi-calendar2-check"></i></span>
                                <span class="flex-grow-1">
                                    <span class="d-block fw-semibold">Visites prevues</span>
                                    <span class="small text-body-secondary">Base de travail terrain a venir</span>
                                </span>
                                <span class="app-dashboard-mini-value">{{ overview.visits_planned }}</span>
                            </a>
                            <a href="{{ path('app_visit_index') }}" class="app-dashboard-mini-card text-reset">
                                <span class="app-dashboard-mini-icon"><i class="bi bi-check2-circle"></i></span>
                                <span class="flex-grow-1">
                                    <span class="d-block fw-semibold">Visites realisees</span>
                                    <span class="small text-body-secondary">Activite validee sur la periode</span>
                                </span>
                                <span class="app-dashboard-mini-value">{{ overview.visits_completed }}</span>
                            </a>
                            <a href="{{ path('app_tour_index') }}" class="app-dashboard-mini-card text-reset">
                                <span class="app-dashboard-mini-icon"><i class="bi bi-signpost-2"></i></span>
                                <span class="flex-grow-1">
                                    <span class="d-block fw-semibold">Tournees en cours</span>
                                    <span class="small text-body-secondary">Execution terrain en temps reel</span>
                                </span>
                                <span class="app-dashboard-mini-value">{{ overview.tour_status.in_progress }}</span>
                            </a>
                            <a href="{{ path('app_offer_index') }}" class="app-dashboard-mini-card text-reset">
                                <span class="app-dashboard-mini-icon"><i class="bi bi-cash-stack"></i></span>
                                <span class="flex-grow-1">
                                    <span class="d-block fw-semibold">Offres en cours</span>
                                    <span class="small text-body-secondary">Dossiers encore ouverts</span>
                                </span>
                                <span class="app-dashboard-mini-value">{{ overview.offers_in_progress }}</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-3 g-xl-4 mt-1">
                <div class="col-md-6 col-xl-3">
                    <a href="{{ path('app_client_index') }}" class="card app-stat-card border-0 h-100 text-reset text-decoration-none">
                        <div class="card-body p-3 p-lg-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <div class="app-section-kicker text-secondary mb-2">Clients</div>
                                    <div class="text-body-secondary small">Base totale</div>
                                </div>
                                <span class="badge rounded-pill text-bg-light">Explorer</span>
                            </div>
                            <div class="h2 fw-bold mb-1">{{ overview.clients }}</div>
                            <div class="small text-body-secondary">Portefeuille exploitable actuellement.</div>
                        </div>
                    </a>
                </div>
                <div class="col-md-6 col-xl-3">
                    <a href="{{ path('app_tour_index') }}" class="card app-stat-card border-0 h-100 text-reset text-decoration-none">
                        <div class="card-body p-3 p-lg-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <div class="app-section-kicker text-secondary mb-2">Tournees</div>
                                    <div class="text-body-secondary small">En cours</div>
                                </div>
                                <span class="badge rounded-pill text-bg-light">Terrain</span>
                            </div>
                            <div class="h2 fw-bold mb-1">{{ overview.tour_status.in_progress }}</div>
                            <div class="small text-body-secondary">Execution commerciale sur le terrain.</div>
                        </div>
                    </a>
                </div>
                <div class="col-md-6 col-xl-3">
                    <a href="{{ path('app_tour_index') }}" class="card app-stat-card border-0 h-100 text-reset text-decoration-none">
                        <div class="card-body p-3 p-lg-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <div class="app-section-kicker text-secondary mb-2">Tournees</div>
                                    <div class="text-body-secondary small">Terminees</div>
                                </div>
                                <span class="badge rounded-pill text-bg-light">Historique</span>
                            </div>
                            <div class="h2 fw-bold mb-1">{{ overview.tour_status.completed }}</div>
                            <div class="small text-body-secondary">Tournees deja cloturees et historisees.</div>
                        </div>
                    </a>
                </div>
                <div class="col-md-6 col-xl-3">
                    <a href="{{ path('app_offer_index') }}" class="card app-stat-card border-0 h-100 text-reset text-decoration-none">
                        <div class="card-body p-3 p-lg-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <div class="app-section-kicker text-secondary mb-2">Revenu</div>
                                    <div class="text-body-secondary small">CA du mois</div>
                                </div>
                                <span class="badge rounded-pill text-bg-light">Finance</span>
                            </div>
                            <div class="h4 fw-bold mb-1">{{ overview.revenue|number_format(0, ',', ' ') }} MAD</div>
                            <div class="small text-body-secondary">Evolution commerciale du mois en cours.</div>
                        </div>
                    </a>
                </div>
            </div>

            <div class="row g-3 g-xl-4 mt-1">
                <div class="col-12 col-xl-8">
                    <div class="card border-0 h-100 app-dashboard-chart-card">
                        <div class="card-body p-3 p-lg-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <div class="app-section-kicker text-secondary mb-2">Activite</div>
                                    <h2 class="h4 mb-1">Rythme des visites et des tournees</h2>
                                    <p class="text-body-secondary small mb-0">Vision mensuelle pour suivre l’execution et la cadence terrain.</p>
                                </div>
                            </div>
                            <div class="app-dashboard-chart-wrap app-dashboard-chart-wrap--lg">
                                <canvas id="dashboardActivityChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-xl-4">
                    <div class="card border-0 h-100 app-dashboard-chart-card">
                        <div class="card-body p-3 p-lg-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <div class="app-section-kicker text-secondary mb-2">Tournees</div>
                                    <h2 class="h4 mb-1">Etat global</h2>
                                    <p class="text-body-secondary small mb-0">Lecture immediate des statuts de tournees.</p>
                                </div>
                            </div>
                            <div class="app-dashboard-chart-wrap">
                                <canvas id="dashboardToursChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-3 g-xl-4 mt-1">
                <div class="col-12 col-xl-6">
                    <div class="card border-0 h-100 app-dashboard-chart-card">
                        <div class="card-body p-3 p-lg-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <div class="app-section-kicker text-secondary mb-2">Performance</div>
                                    <h2 class="h4 mb-1">Visites par commercial</h2>
                                    <p class="text-body-secondary small mb-0">Comparatif rapide des volumes d’activite equipe.</p>
                                </div>
                            </div>
                            <div class="app-dashboard-chart-wrap">
                                <canvas id="dashboardCommercialsChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-xl-6">
                    <div class="card border-0 h-100 app-dashboard-chart-card">
                        <div class="card-body p-3 p-lg-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <div class="app-section-kicker text-secondary mb-2">Revenu</div>
                                    <h2 class="h4 mb-1">Evolution du chiffre d'affaires</h2>
                                    <p class="text-body-secondary small mb-0">Tendance sur les derniers mois pour garder le cap.</p>
                                </div>
                            </div>
                            <div class="app-dashboard-chart-wrap">
                                <canvas id="dashboardRevenueChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
