{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}
    <section class="d-flex flex-column gap-3">
        <div class="app-page-hero app-page-hero-dark rounded-5 p-3 p-lg-4">
            <div class="position-relative">
                <div class="row g-3 align-items-end">
                    <div class="col-xl-7">
                        <div class="app-section-kicker text-white-50 mb-2">Vue direction</div>
                        <h1 class="h2 fw-bold mb-2">Pilotage commercial</h1>
                        <p class="mb-0 text-white-50 small">Suivez rapidement l'activite terrain, les offres et l'etat des tournees.</p>
                    </div>
                    <div class="col-xl-5">
                        <div class="d-grid gap-2 d-sm-flex justify-content-xl-end flex-wrap">
                            <form method="post" action="{{ path('app_dashboard_assign_clients') }}">
                                <button class="btn btn-light px-4" type="submit"><i class="bi bi-diagram-3 me-2"></i>Affecter</button>
                            </form>
                            <form method="post" action="{{ path('app_dashboard_rebuild_markets') }}">
                                <button class="btn btn-outline-light px-4" type="submit"><i class="bi bi-arrow-repeat me-2"></i>Recalcul</button>
                            </form>
                            <form method="post" action="{{ path('app_dashboard_generate_tours') }}">
                                <button class="btn btn-primary px-4" type="submit"><i class="bi bi-signpost-split me-2"></i>Generer tournees</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-md-6 col-xl-4">
                <a href="{{ path('app_client_index') }}" class="card app-stat-card border-0 h-100 text-reset text-decoration-none">
                    <div class="card-body p-3">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <div class="app-section-kicker text-secondary mb-2">Base clients</div>
                                <div class="text-body-secondary small">Total clients</div>
                            </div>
                            <span class="badge rounded-pill text-bg-light"><i class="bi bi-buildings me-1"></i>Ouvrir</span>
                        </div>
                        <div class="h2 fw-bold mb-0">{{ overview.clients }}</div>
                    </div>
                </a>
            </div>
            <div class="col-md-6 col-xl-4">
                <a href="{{ path('app_visit_index') }}" class="card app-stat-card border-0 h-100 text-reset text-decoration-none">
                    <div class="card-body p-3">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <div class="app-section-kicker text-secondary mb-2">Terrain</div>
                                <div class="text-body-secondary small">Visites realisees</div>
                            </div>
                            <span class="badge rounded-pill text-bg-light"><i class="bi bi-check2-square me-1"></i>Ouvrir</span>
                        </div>
                        <div class="h2 fw-bold mb-0">{{ overview.visits_completed }}</div>
                    </div>
                </a>
            </div>
            <div class="col-md-6 col-xl-4">
                <a href="{{ path('app_tour_index') }}" class="card app-stat-card border-0 h-100 text-reset text-decoration-none">
                    <div class="card-body p-3">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <div class="app-section-kicker text-secondary mb-2">Tournees</div>
                                <div class="text-body-secondary small">En cours</div>
                            </div>
                            <span class="badge rounded-pill text-bg-light"><i class="bi bi-signpost-2 me-1"></i>Ouvrir</span>
                        </div>
                        <div class="h2 fw-bold mb-0">{{ overview.tour_status.in_progress }}</div>
                    </div>
                </a>
            </div>
            <div class="col-md-6 col-xl-4">
                <a href="{{ path('app_offer_index') }}" class="card app-stat-card border-0 h-100 text-reset text-decoration-none">
                    <div class="card-body p-3">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <div class="app-section-kicker text-secondary mb-2">Revenu</div>
                                <div class="text-body-secondary small">CA du mois</div>
                            </div>
                            <span class="badge rounded-pill text-bg-light"><i class="bi bi-cash-coin me-1"></i>Offres</span>
                        </div>
                        <div class="h3 fw-bold mb-0">{{ overview.revenue|number_format(2, ',', ' ') }}</div>
                    </div>
                </a>
            </div>
            <div class="col-md-6 col-xl-4">
                <a href="{{ path('app_visit_index') }}" class="card border-0 h-100 text-reset text-decoration-none">
                    <div class="card-body p-3">
                        <div class="text-body-secondary small text-uppercase mb-2">Visites prevues</div>
                        <div class="h3 fw-bold mb-1">{{ overview.visits_planned }}</div>
                        <div class="small text-body-secondary">Toutes les visites encore programmees.</div>
                    </div>
                </a>
            </div>
            <div class="col-md-6 col-xl-4">
                <a href="{{ path('app_client_index') }}" class="card border-0 h-100 text-reset text-decoration-none">
                    <div class="card-body p-3">
                        <div class="text-body-secondary small text-uppercase mb-2">Prospection</div>
                        <div class="h3 fw-bold mb-1">{{ overview.prospects }}</div>
                        <div class="small text-body-secondary">Clients potentiels a convertir.</div>
                    </div>
                </a>
            </div>
        </div>

        <div class="card border-0 overflow-hidden">
            <div class="card-body p-3 p-lg-4 d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
                <div>
                    <div class="app-section-kicker text-secondary mb-2">Analyse detaillee</div>
                    <h2 class="h5 mb-1">Toutes les statistiques utiles sont centralisees dans la rubrique Stat.</h2>
                    <p class="text-body-secondary mb-0 small">Consulte les graphiques, les tendances, les zones les plus fortes et les commerciaux les plus actifs.</p>
                </div>
                <a href="{{ path('app_stats_index') }}" class="btn btn-primary rounded-pill px-4">
                    <i class="bi bi-pie-chart me-2"></i>Voir toutes les stats
                </a>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <a href="{{ path('app_tour_index') }}" class="card border-0 h-100 text-reset text-decoration-none">
                    <div class="card-body p-3">
                        <div class="text-body-secondary small text-uppercase mb-2">Tournees terminees</div>
                        <div class="h3 fw-bold mb-1">{{ overview.tour_status.completed }}</div>
                        <div class="small text-body-secondary">Tournees cloturees par les commerciaux.</div>
                    </div>
                </a>
            </div>
            <div class="col-md-6">
                <a href="{{ path('app_offer_index') }}" class="card border-0 h-100 text-reset text-decoration-none">
                    <div class="card-body p-3">
                        <div class="text-body-secondary small text-uppercase mb-2">Offres en cours</div>
                        <div class="h3 fw-bold mb-1">{{ overview.offers_in_progress }}</div>
                        <div class="small text-body-secondary">Dossiers a suivre activement.</div>
                    </div>
                </a>
            </div>
        </div>
    </section>
{% endblock %}
