<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>Connexion</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="{{ asset('assets/theme/app.css') }}">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    </head>
    <body class="app-body app-login d-flex align-items-center" style="font-family: 'Manrope', system-ui, sans-serif;">
        <div class="container-fluid px-3 px-lg-4 py-4 py-lg-5">
            <div class="row justify-content-center">
                <div class="col-12 col-md-8 col-lg-6 col-xl-5 col-xxl-4">
                    <div class="app-login-minimal-shell">
                        <div class="text-center mb-4">
                            <img src="{{ asset('assets/img/Logo-RM-Final.png') }}" alt="Relais Medical" class="app-login-logo app-login-logo-large mb-3">
                        
                        </div>

                        <div class="card app-login-card border-0">
                            <div class="card-body p-4 p-lg-5">
                                {% if error %}
                                    <div class="alert alert-danger border-0">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                                {% endif %}

                                <form method="post" class="d-grid gap-3">
                                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
    <h1 class="h3 fw-bold mb-2">Connexion</h1>
                            <p class="text-body-secondary mb-0">Accedez a votre espace de travail.</p>
                                    <div>
                                        <label for="inputEmail" class="form-label fw-semibold">Email</label>
                                        <div class="input-group input-group-lg">
                                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                            <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control" autocomplete="email" placeholder="nom@relais-medical.local" required autofocus>
                                        </div>
                                    </div>

                                    <div>
                                        <label for="inputPassword" class="form-label fw-semibold">Mot de passe</label>
                                        <div class="input-group input-group-lg">
                                            <span class="input-group-text"><i class="bi bi-key"></i></span>
                                            <input type="password" name="password" id="inputPassword" class="form-control" autocomplete="current-password" placeholder="Saisissez votre mot de passe" required>
                                        </div>
                                    </div>

                                    <div class="d-flex align-items-center justify-content-between gap-3">
                                        <div class="form-check mb-0">
                                            <input class="form-check-input" type="checkbox" name="_remember_me" id="rememberMe">
                                            <label class="form-check-label" for="rememberMe">Se souvenir de moi</label>
                                        </div>
                                        <i class="bi bi-shield-lock text-secondary"></i>
                                    </div>

                                    <button class="btn btn-primary btn-lg w-100" type="submit">Se connecter</button>
                                </form>

                                <div class="app-login-demo mt-4">
                                    <div class="small text-uppercase text-body-secondary mb-2">Compte de demonstration</div>
                                    <div class="fw-bold">admin@relais-medical.local</div>
                                    <div class="text-body-secondary">Mot de passe : <span class="fw-semibold text-dark">Relais2026!</span></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </body>
</html>
