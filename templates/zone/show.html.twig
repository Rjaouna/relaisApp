{% extends 'base.html.twig' %}

{% block title %}Detail zone{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <div class="text-body-secondary small text-uppercase mb-2">Fiche zone</div>
            <h1 class="h2 mb-1">{{ zone.name }}</h1>
            <p class="text-body-secondary mb-0">{{ zone.city.name }}</p>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('app_zone_index') }}" class="btn btn-outline-secondary rounded-pill px-4"><i class="bi bi-arrow-left me-2"></i>Retour</a>
            <a href="{{ path('app_zone_edit', {id: zone.id}) }}" class="btn btn-primary rounded-pill px-4" data-crud-modal-url="{{ path('app_zone_edit', {id: zone.id}) }}">Modifier</a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-5">
                <div class="card-body p-4">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Code</dt>
                        <dd class="col-sm-8">{{ zone.code ?: 'Non defini' }}</dd>
                        <dt class="col-sm-4">Ville</dt>
                        <dd class="col-sm-8">{{ zone.city.name }}</dd>
                        <dt class="col-sm-4">Statut</dt>
                        <dd class="col-sm-8">{{ zone.isActive ? 'Active' : 'Inactive' }}</dd>
                        <dt class="col-sm-4">Commerciaux</dt>
                        <dd class="col-sm-8">{{ zone.commercialsCount }}</dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-5">
                <div class="card-header bg-white border-0 pt-4 px-4">Notes</div>
                <div class="card-body">
                    {{ zone.notes ?: 'Aucune note pour le moment.' }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
