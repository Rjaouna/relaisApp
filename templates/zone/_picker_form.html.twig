<div class="modal-header">
    <h5 class="modal-title">Ajouter une zone</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
</div>
{{ form_start(form, {
    action: zone.id ? path('app_zone_edit', {id: zone.id, picker: 1}) : path('app_zone_new', {picker: 1}),
    attr: {
        'data-zone-ajax-form': true
    }
}) }}
    <div class="modal-body">
        <div class="row g-3">
            <div class="col-12">{{ form_row(form.name) }}</div>
            <div class="col-12">{% include '_partials/_city_select_field.html.twig' with { field: form.city } %}</div>
            <div class="col-12">{{ form_row(form.code) }}</div>
        </div>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
        <button type="submit" class="btn btn-primary">Ajouter la zone</button>
    </div>
{{ form_end(form) }}
