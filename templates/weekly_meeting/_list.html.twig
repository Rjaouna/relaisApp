<div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>Reunion</th>
                <th>Perimetre</th>
                <th>Agenda</th>
                <th>Suivi</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for meeting in meetings %}
                <tr>
                    <td>
                        <a class="fw-semibold text-decoration-none" href="{{ path('app_weekly_meeting_show', {id: meeting.id}) }}">{{ meeting.title }}</a>
                        <div class="small text-body-secondary">{{ meeting.meetingDate ? meeting.meetingDate|date('d/m/Y H:i') : 'Sans date' }}</div>
                    </td>
                    <td>{{ meeting.teamScope ?: 'Equipe commerciale' }}</td>
                    <td>
                        <div>{{ meeting.agenda ? (meeting.agenda|length > 70 ? meeting.agenda|slice(0, 70) ~ '...' : meeting.agenda) : 'Aucun agenda' }}</div>
                        <div class="small text-body-secondary mt-1">Organisateur : {{ meeting.organizer ? meeting.organizer.fullName : 'Non defini' }}</div>
                    </td>
                    <td>
                        <span class="badge rounded-pill {{ meeting.status == 'cloturee' ? 'text-bg-success' : (meeting.status == 'tenue' ? 'text-bg-warning' : 'text-bg-light') }}">{{ meeting.status|title }}</span>
                        <div class="small text-body-secondary mt-2">{{ meeting.attendees|length }} participant(s)</div>
                    </td>
                    <td class="text-end">
                        <div class="btn-group btn-group-sm">
                            <a href="{{ path('app_weekly_meeting_show', {id: meeting.id}) }}" class="btn btn-outline-secondary rounded-pill">Voir</a>
                            <a href="{{ path('app_weekly_meeting_edit', {id: meeting.id}) }}" class="btn btn-outline-primary rounded-pill" data-crud-modal-url="{{ path('app_weekly_meeting_edit', {id: meeting.id}) }}">Editer</a>
                            <button type="button" class="btn btn-outline-danger rounded-pill" data-crud-delete-url="{{ path('app_weekly_meeting_delete', {id: meeting.id}) }}" data-crud-refresh-url="{{ path('app_weekly_meeting_list') }}" data-crud-confirm="Supprimer cette reunion commerciale ?">Supprimer</button>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="5" class="text-center py-4 text-body-secondary">Aucune reunion commerciale disponible.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
