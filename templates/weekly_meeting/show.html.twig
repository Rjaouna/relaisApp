{% extends 'base.html.twig' %}

{% block title %}Detail reunion commerciale{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <div class="text-body-secondary small text-uppercase mb-2">Reunion commerciale</div>
            <h1 class="h2 mb-0">{{ meeting.title }}</h1>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('app_weekly_meeting_index') }}" class="btn btn-outline-secondary rounded-pill px-4"><i class="bi bi-arrow-left me-2"></i>Retour</a>
            <a href="{{ path('app_weekly_meeting_edit', {id: meeting.id}) }}" class="btn btn-primary rounded-pill px-4" data-crud-modal-url="{{ path('app_weekly_meeting_edit', {id: meeting.id}) }}">Modifier</a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-5 h-100">
                <div class="card-body p-4">
                    <span class="badge rounded-pill {{ meeting.status == 'cloturee' ? 'text-bg-success' : (meeting.status == 'tenue' ? 'text-bg-warning' : 'text-bg-light') }} mb-3">{{ meeting.status|title }}</span>
                    <dl class="row mb-0">
                        <dt class="col-sm-5">Date</dt>
                        <dd class="col-sm-7">{{ meeting.meetingDate ? meeting.meetingDate|date('d/m/Y H:i') : 'Non renseignee' }}</dd>
                        <dt class="col-sm-5">Perimetre</dt>
                        <dd class="col-sm-7">{{ meeting.teamScope ?: 'Equipe commerciale' }}</dd>
                        <dt class="col-sm-5">Organisateur</dt>
                        <dd class="col-sm-7">{{ meeting.organizer ? meeting.organizer.fullName : 'Non defini' }}</dd>
                        <dt class="col-sm-5">Participants</dt>
                        <dd class="col-sm-7">{{ meeting.attendees|length }}</dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-5">
                <div class="card-body p-4">
                    <div class="small text-uppercase text-body-secondary mb-2">Participants concernes</div>
                    <div class="d-flex flex-wrap gap-2 mb-4">
                        {% for attendee in meeting.attendees %}
                            <span class="badge rounded-pill text-bg-light">{{ attendee.fullName }} · {{ attendee.roleLabels ?: 'Utilisateur' }}</span>
                        {% else %}
                            <span class="text-body-secondary">Aucun participant selectionne.</span>
                        {% endfor %}
                    </div>
                    <div class="small text-uppercase text-body-secondary mb-2">Ordre du jour</div>
                    <p class="mb-4">{{ meeting.agenda ?: 'Aucun agenda renseigne.' }}</p>
                    <div class="small text-uppercase text-body-secondary mb-2">Decisions prises</div>
                    <p class="mb-4">{{ meeting.decisions ?: 'Aucune decision formalisée.' }}</p>
                    <div class="small text-uppercase text-body-secondary mb-2">Actions a suivre</div>
                    <p class="mb-4">{{ meeting.actionItems ?: 'Aucune action de suivi.' }}</p>
                    <div class="small text-uppercase text-body-secondary mb-2">Participants</div>
                    <p class="mb-0">{{ meeting.participantsSummary ?: 'Aucun participant renseigne.' }}</p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
